'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Rigas llcl)!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Brieži, zaki mūsu mežos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vilki, lāťi araiu mežos!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiši dziedaja:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vimbas, turskas mūsu jūrā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skaistas meitas mūsu ciemā!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meitas dziedaja:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Brangi puiši mūsu ciemā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzēraju puiši svešā ciemā!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lieli putni, mazi putni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ēi ēo, putnini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu jums ir laiks piecelties</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ci co, ci co!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Treknas lestes mūsu jūrā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vājas lestes mazā jūrā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">brieži, zaki mūsu mežā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vilki, lāťi araju mežos!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sēta, Daba, Pasaule VII (1892), S. 49 (Pr. Kārkluvalks).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visu gadu åānis brauca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu atbrauca šovakar,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nojūdza ~ sakas krita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sudrab paugas skaneja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visu gadu Jānis brauca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu atbrauca šovakar.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Jānu bērni sagaidija,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">alutinu izbrūveja.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Sovakar dievinš brauca —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visa zeme norībei,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visa zeme norībei,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skanei pieši noleoot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lb. Sovakar dievinš brauca</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rībei zeme atjājot,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rībei zeme atjājot,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skani pieši noleoot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šovakar dievinš brauca —,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur dievinš kumelin lik?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kumel lika puku dārza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sēja vara pinikliem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāniš jāju par gadskārtu</V>
'.
