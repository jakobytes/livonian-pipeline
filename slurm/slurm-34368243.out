'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tec, saimniec, raudzit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kēvam piedzimis kumelis (!)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar lauku pieru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zvaigsnu deke mugare,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar garu astu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lieli putni, mazi putni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ēi-o! putnini!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu jums laiks piecelties,</V>
'.
