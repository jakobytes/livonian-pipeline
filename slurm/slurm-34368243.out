WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apjāj manu tīrumin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">izmin usnes, izmin dadžus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai aug tīra labibina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nem, Jāniti, melnu zirgu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apjāj manus tīruminus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">izmin dadžus, izmin zāles,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai aug tīra labibina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pērc, Jāniti, melnu zirgu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apar manu rudzu lauku,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">izmin smilgus, izmin lāťus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai aug manim tīri rudzi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Dies nāc šovakar</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apraudzit mūs laukus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zāliti nīdedams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vārpinus celdams.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lavakaru, rudzu lauka!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dies gāja šovakar</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa mūsu rudzu lauk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zāliti mīdami,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vārpinus celdami.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labvakari, rudzu druva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka dievinš tev līdzeis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vārpinasi rēdeties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ziedinasi noziedet!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ai rudziti rogainiti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tavu dārgu augumin!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tevis dēl Vāczeme</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta naudu kaldina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labvakari, kāpstu dārza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā dievinš tev līdzeis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">galvinas iegriezties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kāpostinus isaudzet.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labvakari, pupu dārza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kādi ziedi iums bija?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ralti ziedi, melni ziedi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tādi ziedi mums bija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visa laba jānu zāle,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko plūc jānu vakara</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vībotnite, papardite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sarkanais ābolinš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visa laba jānu zāle,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko plūc jānu vakara</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vībotnite, papardite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sarkanbaltais ābolinš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visas jānu zāles zied,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">papardite vien nezied —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">papardite jānu zāle,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas zied jānu naksnina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānits gāja siena plauti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs kažoki mugurāi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nenoplāva gailam nestu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne vēršami kumosinu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nenoplāva gailam nasti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne kazai kumosit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānis gāj sienu plaut,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs kaž́oku mugura.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nenoplāvu gailam nast,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne kazamu kumosin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāns gāja sienu plaut,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs kaž́oki mugura.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nenoplāva gailam(!) naste(!),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne kazinam mut(e)s pil.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānis gāja sienu plaut,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs kažoki mugura.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nenoplāv(u) gailam nastu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne kazam kumosin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sit, Dāniti, vara bungas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vārtu stabu galina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai celas jāna māte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">spilvenos guledam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Sit, Jāniti, vara bungu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai atmož́as jāna māte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">spilveninus guledams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neko nedzirdeja.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Guli, guli, saimaniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visa tava saime gul —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūka dobus izraveja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaza škina kāpostus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas gulei jānu nakti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam rudziši lažā krit!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas gulei jānu nakti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūžam sievu nedabus!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāna nakti nepazīstu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kura sieva, kura meita:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visam zalš</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ozola vainags galva.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāburgami slinkas puišas —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visiem vārti nepuškoti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānu bērni kalna kāpa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zālu naste mugura.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zālu nasti saimniecei deva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saimniece deva telitem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saimnieks sirmiem kumeliem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānis kāpu kalnina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zālu naste mugura.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāe, lāniti, leiina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dod manam telinam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāc āre, saimeniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mēs tev teiksim govu laimi —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">stalli lielas raibas govis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mazas raibas telites.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāc āre, saimeniek,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— mēs iums teiksim zirgu laimi —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">stalli lieli bēri zirgi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mazi bēri kumelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānu nakts ir gara nakts,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jānu nakti auksta rasa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Aitas jānu nakti jatur rasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad būs baltas villainites.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja gribati baltas aitas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzenat aitas piegujam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānu nakti zelta rasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur aitinas mazgajās,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai būs aitam balti jēri</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta ka purva pūpolites.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labvakari, jāna māte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai gaidiji jāna bērnus?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai būs savu istabinu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ziediniemi puškojusi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lapinami kaisijusi?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas godiga jāna māte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atver logu gaididama.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es pats savu istabinu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ziediniemi izpuškoju,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lapinami izkaisiju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak Jāniti, labais tētinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tu vedi vezuma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meitam zīlu vainadzinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puišam caunu cepures.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānis nāca, Jānis nāca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka mēs Jāni mielosim?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sildam pienu, cepam rauš́us,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta mēs āni mielosim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānis nāk, Jānis nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā mēs jāni mielosim?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gepsim raušus, sildsim pienu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to (!) mēs jāni mielosim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāns nāk, Jāns nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko mēs Jānam dosim?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gepsim raušus, sildam pienu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta mēs Jānu mielosim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānis nāk, Jānis nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko mēs Jānim mielosim?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gepsim raušus, sildsim</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to mēs Jānim mielosim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Alu, alu, jānu tēvs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tev aug mieži tīruma!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sieru, sieru, jānu māte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tev ir govis laidara!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man kazinu vilks aiznesa</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">paša jānu vakara.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāna bērni galu prasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur mēs galu dabusim!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vilks aiznesa mums kazinu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">paša jānu vakara.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas tur spīd, kas tur spīd</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz vienu zālu galina?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur ir viena skaista meitin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas mazga actinas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jāna zāle, jāna rasa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jūriš krāce, jūriš rūcu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko ta jūre ierijes?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Daž́u labu tēvas(!) dēlu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Triduridurīdam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Katrinu māsinu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kristīne, Katrīne,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie mūsu māsinas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Krišjānis, Dāniēlis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie mūsu brālin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Triduridurīdam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">raibas zekes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rakstitas kurpes!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Katrīna, Kristīna, tie mūs(u) māsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Krišjānis, Dānielis, tie mūsu brālin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Katrina māsina, nesaki mātei,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka raibas zekes ir kāja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un rakstitas kurpes.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Teci, teci, meitina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gar jūras malu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai es tev neteicu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka tu lepni staigaji:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">katru dienu balts kreklis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar zīda lindraku,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">izrakstitas zekes</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kurpem kāja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, tec, meitina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gal jūras malu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai es tevim neteicu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka tu lepni staigā:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ikdienas balts kreklis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zīd lindracinis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rakstitas zekites,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kurpites kāja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Strop, strop, jērini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">strop, strop, kazlelini(!)!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mēs paši stropam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz citam mājam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Strip(u), strop(u) jērin(u),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">strup kazalinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sik sproginu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gar astinš — tie mūsu jērinu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">5a. Stropp, mani jērini, stropp, kazlenini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pats ari stroppeiu bārbanu vakarā!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur tu augu, smuka meitin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es tevi neredzeju?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es uzaugu rožu dārza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">starp rožu lapinem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur tu augu, smuka puisits,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es tevi neredzei?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es uzaugu liela meža,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">starp staltem ozolem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pūt, bālinu, varu tauri</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vārtu stabu galina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai mostasi tautu meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">spilvenos guledam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Skanigi dzieda mazais gailis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mana puku dārza apakš loga.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne man miegu, ne man darbu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">putni vien ir jaklausas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dziedi skani, mazputnip,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man puku dārzinā!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja tu skani nedziedasi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">palaidišu vanadzin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi ciema gaili dzied,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs gailis vien nedzied:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs gailis sapinies</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ciem meit pakulas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es savam brūtganam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jēru vill eimdus ad,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai vinš mani tā mīle,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka aitin sav jērin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es redzēju savu brāli</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jūra šūpojamies.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es gribeju roku dot —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vilni aizšūpoja laivu prom.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Reti, reti tie silini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ar baltiem ziediem zied,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">reti, reti tās meitinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas pie puišu valodam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dreb, dreb, apses lap,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad vējinš tevi purina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tā dreb puiš(a) dvēselit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad meitinas ieraug(a).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja tas puisens vairen dails —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">blēdig vinu sirds.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja tas ābels vairen sarkans —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iekša vinam tārpi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jo tas ābols varen salds —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tārps ir vinas vidu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jo tas puisens varen stalts —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">velns ir vinam sirdi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ābol ēd un nemizo...</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas meitin mīl un nebuco...</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Liepa žaud (~ žāve) meitam ceimdus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">liepai eimdi pašam aug,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">liepai eimdi pašam aug,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">katra zara galina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ozolite zem zarin(a),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam tu augi lejina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meitas tavus zarus lauza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kalnina stāvedam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Laužat, meitas, ko lauzdami,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">galoksnites nelaužat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai palieku galoksnites,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur putniemi nolaisties.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es ar saV bäleli^ garam rož(u) pilij braucu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Apgriežas mans bäliš, pirkt man rož vai^adzi^u.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es ar savu baleliiiu garam rožu pilij braue,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Apgriežase mans bälišu, pirkt man rožu vaigadzig,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">garam rožu pilij braue. Mans bälišu man nopirka</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pirkt man rožu vaiijadziij. Visapkärti lietus lija,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ermu, ermu vaiijadziiju. . Mans bälišu man novidü</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saule ritinaja. Visapkärti lietus</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pirka ermu, ermu vaiijadzig, ermu, ermu vaipadzir,i!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lija, vidü saule ritinaj, vidü saule ritin aj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Brālits savu īstu māsu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vientuliba audzinaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tautiets sola simt dalderu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man par vinas rādijum.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sol, tautieti, otru simtu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad vedišu sētina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad vedišu sētina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad būs tava līgavin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tav cimdinu aditaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tav cimdinu aditaj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tav gultinu taisitaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad aiziesi — pavadisi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad pārnāksi — sagaidisi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīlus vārdus tevim dos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tavu dzīvi aplaimos.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Būs tav sētu slaucitaj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atslēdzinus glabataj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es dievinam izlūdzas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sev trijadu labumin:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">labu zirgu cela braukti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mājas gudru līgavin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to trešajo labumin:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no dievinu(!) veselib.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">No jūrinas mala peld (~ ispeldeja)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">divi sveši kumelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vienam bija zelta sedli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">otrai sudrab iemauktiii.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kam tie zelta sedli bija,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam es sēdeš mugura.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kam tie sudrab iemauktin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to pie rokas vedišu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kumelin, kumelin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu man kauna padarij:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tev kājina paslidaja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man nokrita cepurit</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jaunas meitas vidina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas godiga mātes meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pacej manu cepurit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas bij kāda vizdeguna,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kājinu paspārdij.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es nejāj pa jūrmal</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bez tēraud zobentip:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jūras balti putnin</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">baida manu kumelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jūras putni, putnini</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">baida manu kumelin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad es jāju gar jūrmalu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">loti ātri, cīrīgi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es savam kumejam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">krustam jūr sienu plāv:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad es gāj brūti raudzit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">krustam cel vien dancei.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, tec, kumelin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neci solu skaitidams!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai es tevim auzas devu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par vienam skaitidams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, tec, kumeliti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neci solu skaitidams!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai es tevim auzas devu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa vienam skaitidams?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Teci, teci, kumelinu:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tevis gaida, manis gaid(a) —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tevis gaida auza sile,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">manis jauna līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Skrej un skrej, kumelin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa ciemas gatvem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">klausies, kam dzirnav ātrak</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas būs man brūt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kāpu kalna raudzities,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kugš puisitis zirgu kul.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kugš puisitis zirgu kul.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas kul savu līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Balta kēva (~ zirgs un) smuka sieva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abi vīram dārgi maksa:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vienam vaid(!) daudz ziepes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">otram daudz pātagas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tevs nopirka kumelin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne paldies nesacija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad pārveda līgavin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad paldies uz paldies.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trīs priedites kalna auga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visiem zari kopa bija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vienu eirtu, otra lūza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">treša līdzi līgojas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māminai trīs meitinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas viena dailuma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vienu jēmu, otra nāce,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">treša līdzi taisijas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur starp Rīgas vārtiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur rožu dārzina —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mamin, mīlais, kā tas ir,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka tie puiši man nemīl?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es gan skaidri mazgajos</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un vel skaisti apgērbjos.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Baltai gan vajg mazgaties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skaisti nevajg apgērbties:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puiši neskatas vis drēbes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skatas tikai dārbu vien.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Veca māte liec(!) man kartes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kāda dzīve man še būs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es grib tavu meitu nemti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai būs nemti, vai atstāti?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Veca māte izliek kartas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kāda dzīve man šeit būs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es grib šeit vien meitin precet:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai precetu, vai atstāt?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tu māminai viena meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaidi kungus, vagarinus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gaidi, gaidi, nesagaidis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kamēr sūna virsu augs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Taisies, gērbies,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sīpel(a) meit(a) —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sen tevi gaidej(a)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kniplok(a) dēls.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Maza, maza meitenit</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">solijasi mana būt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu isauga liela meit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">negrib vairak mana būt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko tu doma, diždeguni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es tev izlūgšu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gan būs māte, kas dos meitu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas prot meitu audzinat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sievas mäte, vilku mate,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai man savu meitin dos?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ej tu elle, elles kruki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savu meitu es nedoš:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mana meita smalka baita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tev sakaltis kažocinš —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad piemīzu, tad smirdeju,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad sakaltu, tad grabeju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es ar savu kažocinu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ikdieninas dumpi tieku:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad piemīzu, tad smirdei,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad sakaltu, tad grabej.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko tu kaitne, ciemas puis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta nav meits vain!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ka bij piedzeries, tad tu kaitna,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka bij gudrs, tad dev rok.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tici, māte, netici,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es būš kalpa puiša līgava:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uzaugdami uzvalkaja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kalpa puiša gredzeni.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi mani radi rauda,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es kalpa līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">plati mani brūni svārki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šauras kalpa kamanas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko jūs raudat, jūs, radini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es kalpa līgavin!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Neraudati jūs, radini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai kalppuišam naudas trūkst?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Daža laba saimeniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam nav maizs garozin</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">daža laba kalpa sieva</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sauja naudu škildina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tētinš brauca Rīga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nem mani līdza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pirka manim zīža kleitu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad mani precesi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad mani precesi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vagara dēli.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tētinš brauca Riga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nēm mani līdzi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">melniem zirgiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaltiem ratiem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pirka man žīda kleitu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad veda manu uz kalnu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai kleits spīda.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur mani preceja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vagara dēli.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jo vagara dēli preceja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jo brāli liedza.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">O paldies brāliem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas mani liedza.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Viens smuks puisis no svešas zemes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no svešas zemes, no labiem laudiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs dailas meitinas pēc vina tīko.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur jūs mani liksiet, tādu lielu dzērajin?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur kannas sklabina, kur brāli kopa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur man sirsnina ar alu laistas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzēreipuisis bēdejas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur būs nemtu līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ralta pukit ezera</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta dzēreja līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Baita pukit atsacej:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Labak ziedu ezera,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">labak ziedu ezera,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne dzēreja sētina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ezera silts ūdens,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzēreja sēta asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labak ziedu ezera,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai pūst dzērajs krodzina!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Dzērei-puika bēdeiusi: „Kur dabušu līgaviń?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trā-ri-ta rī-ri-ta trā-ri-ta-rā.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzērei-puika bēdejas(i):</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Kur dabušu līgavin(u)?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ralta pukit ezeri,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas dzēreja līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Balta pukit atsacija:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">labak dūnu ezera,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne dzēreja līgavin.</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">Pr 53 (V): Kōzgõnd-loul.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzēreipuisis bēdejas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur būs nemtu līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ralta pukit ezera</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta dzēreja līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Baita pukit atsacej:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Labak ziedu ezera,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">labak ziedu ezera,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne dzēreja sētina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ezera silts ūdens,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzēreja sēta asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labak ziedu ezera,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai pūst dzērajs krodzina!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Dzērei-puika bēdeiusi: „Kur dabušu līgaviń?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trā-ri-ta rī-ri-ta trā-ri-ta-rā.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1a. Redz kur, redz kur luksis nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">redz kur luksis vazajas:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīkis rokās, vīzes kājā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīku drān par nezdrācin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Redz kur, redz kur jaunskungs nāk:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">taisns tā kā svece</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">niedris rokā, kurpes kājā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zalais zīžu nezdocenš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vel man bija šovasar</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pašai sava vala būt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vel man bij dažu labu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tautas dēlu kaitinat,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne pie tāda slendermana</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vadit dienas asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko, meitin, nu vairs raudi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tava pasa vaina bij,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tava paša vaina bij,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā padomu neprasij(a),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā padomu neprasij(a),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad tu tautam roku devi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Devusi roku būt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam tu devi gredzentin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam tu devi pašu sev.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Roku padod, roku atnem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bet kas atdos gredzentin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gredzentinš tev ieveda</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tādas žūpa tautinas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tautiets, man precedam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">solij manim kājas aut,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pus mūžin būs nodzīvot</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīž́u auklu nenovij.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gulbis gul ezareja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es gul lauž́u valades(!).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gulbis cēlas no ezara,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es celas no laužu valoda.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Strauji, strauji upe tek(a)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gar brālina (~ bālina) nam duriem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāj, brāliti, droši pāri,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neslīks tavis kumelin:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakša ir baita smilt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">virsu dzīdrais ūdentiš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zobens grieza baltas smiltis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ūdens skalo (~ mazga) kumelin</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kumelinam spoža spalva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vel jo spoži apauši.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mazs, mazs krodzinš, vārda Brasla,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur skan vijoles un basa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie zilas acis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie kāʼlu galvi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne räukist räukõbõd,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu nāku vilks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie blundi mati,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas zilas acis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie manu sir(d)sninu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">beidigu daʼr.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ka tas ieraugu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no prieka raudu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apšēžus blakam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">asaras slauk.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rītos, kad gaili dziʼed,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pēc pusnakts agri</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie kuldas stāvošai</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man uguns jākur.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gaiši deg liesminas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzirksteles kvēlo.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es skatos uguni</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un grimstu bēdas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kīńďõld siz vierõstõ</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">minnõn pids poš́kõ mō.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pǟva kui irgõn voľ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">äb tieda, kui loptab.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vien divi plavus es saplāvu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sarkan baltam pukitem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pats es māku sienu plaut,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pats izkapti trininat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad es it ilgu laiku</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nav redzeis mīlako.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bet šovakar it vēlu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es vinu redzeju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viens un viens es esmu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur es draugu jemšu?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lešu, iež, uz lauku,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meklešu sev draugu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Redzies, redzies, tāl,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur pie upes mala</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">smuka meitin lokam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">balta rozit roka.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Labdien, smuka meitin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko no rožem pīsiet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Pīsim, pīsim kronu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un ar vainadzinu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Likšu, likšu galva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad es brūte būšu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„lesim, iesim mājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">liksim rokas kopa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Un pēc vecas tiesas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mācitajs savienas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Krauklis seida ozola,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta spēles rocina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">oktrairidra, oktrairidra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta spēles rocina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai, krauklit, tu redzē,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur aizvedu mūs māsin?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Pa mežiem, pa puriem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa sīkiemi krūminiem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur aizved mūs māsin</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz bagatu Vācu-zem.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Oi vēi vanadzin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">augsti lidinaja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu atskrei no tālu zem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai redzeja manu brūt?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es vakar nāc caur to pilsēt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tav brūte(i) kāzas dzer.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Redzei, redzei tavu brūt</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie laulibas vedam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Divi bija pie rokas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trešais līdzi gāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ceturtami sirdi gul,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piektais tas pagība,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sestais pat pie logu seid,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">raksta savu grāmatu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta nav tava līgavina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tev ir galva nekemmeta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tev ir galva nekemmeta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">div laulati gredzeni.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nelūko pēc manu galv,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atraitnam ir sērs mūžs</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar div laulatiem gredzeniem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es biju ganes, es biju ganes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dziedaja mazi putnini.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Strazdiš dzieda galoksnina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lagzdigala pazaros.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Strazdiš prasa lagzdigalam:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Kas tur jāj, ka zeme rīb?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Tur jāi mūsu bāleliš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam jaieti zaldates.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viena roka zirgu tur,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">otra roka slauku asaras</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">balta zīžu nezdadzina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visapkārt bij zelti burti ierakstita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vide mīlaks sirsnin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Divi brāli kara jāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abi jāja raudadams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Div māsin rož́u dārze</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puške brālam cepurus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1b. Div dūdini gaisa skreja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abi skreja dūdodam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Div brāli kara jāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abi jāja domadams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai būs jāti, vai nejāti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai, paliktu šai zeme?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lec, māsin(a), rožu dārza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puško brālam cepurit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dziedadami appuškoja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">raudadami pavadij.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Tur aiz tiem klosters mūriem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur aiz tiem melnam sienam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vien meitin dievu lūdz,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta pōlab iľ eńďž́brudgana,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam brūtgans kara gājs.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Celnieks bijis, celnieks būšu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">celnieks gribu mūžam būt.</V>
L 2.
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Spēle, dance vis caur nakti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar vien jaunu meitin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vel šis spēle nav pabeigta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sāk ši meita raudata.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Neraud, neraud, jauna meitin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es tev godig aizmaksaš...</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lūgšu lūdzu, jātinieki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sedlo man šo bēru kumel!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pajai vienu gabalinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzird vien pulksten zvana.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Lūgšu lūdzu, zvanitaj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko jūs šeitan zvanet</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Zvanam vienu jaunu puišu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žēluma nomirusi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pajaj vienu gabalinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">redz vien kapu rokam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Lūgšu lūdzu, kaprace,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jūs šeitan rokat?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Rokam vienu jaunu puišu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žēluma nomirusi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pajai vienu gabalinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">redz vien līki nesam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Lūgšu lūdzu, līknese,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">noliekat šo līki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">attaisiet to zārku vāku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu vin paliek iten bāla.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu vinš izvelk spožu zoben,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iedur sava sirde.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Liekat nu mus abus divus</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iekš šo vienu zārku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Pirmo dance es uzvedu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savu jaunu līgavin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nokrīt rožu vainadzinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">paklūp kreisa kāja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu viš pajem sa va kleipi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ieneš mīksta gultina:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Sak man, mlla sirds pukiti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vaj tu ko neiekāro?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai nekāro vīn ar medu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai saldčjas ābolus?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Neiekāro vīn ar medu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne saldejus ābolus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Taisiet manim zeltu šūplu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar sudräba šnorinam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs dienina, trīs naksnina</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šūpo savu līgavin(u).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vedait man tur vācu kapos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie tiem lieliem muižniekiem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar tiem sešiem dzelteniem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kād es tiku brūte vest,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam zvaigznite pierite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zvaigzne deke mugare.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Taisiet manim zelta zārku</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar sudräbas kājinam.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Klau, klau, kur pulkstens zvana,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">diezin, kas miruse.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vien smuk meitin miris,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta miris želumas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es käp uz augstu kalnu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un skatoš(!) jürina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur redz vien laivin peldam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur ir mans mllais draugs</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(— mljakais).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta laivin peld pie manas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un lüdzas bucoties.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Ak meitin, tu büt smuka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad tu jau bagats büt."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Priekš manu augstu godu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu es par nabagu.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Kad es priekš teV par nabag,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad grib uz kloster iet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad grib uz kloster iet</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un dieva berninš büt."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es redz, kad man jäj pakal</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar štaltu beru zirg,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vinš klopeja aiz durvim:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Laiž iekša, smuka meit!"</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu iznäk veca nonne</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un prasa, ko vinš grib.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Lai iznäk j auna nonne,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas vakar näkusi."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Te naV neviena nonne,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas vakar näkusi."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Ja naV neviena nonne,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas klosters aizdegses."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu isnäk jauna nonne</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar melnu zlda kleit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu gäju vin diV ci</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par naines [näves?] ieleju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad vinš j au lödzas dzert</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no naines bikeri.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad vinš j au bija dzeris,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad vinam sirds pärspräg.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar savu nažu spicu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es vinam kapu rok.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar saviem gariem matiem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es vinu ielaidu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar savam baltam rokam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es vinu apraku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar savam rožu lüpam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es vinu aplasu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Redz, ta kläj jauniem puišiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas dzen pec bagatib.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Es nevaru, es neiet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man galvinu gaužam säp."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gulu, gulu, miegs nenäk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakš kuplu lagzdu krüm.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Atnäk mana mlla brälit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Celies, brälin, näe man lldz!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es teV došu sešas zirgus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas sešas b</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">s büs."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Es nevaru, es neiet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man galvinu gaužam säp."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gulu, gulu, miegs nenäk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakš kuplu lagzdu krüm.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Atnäk mana mlla mäsa:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Celies, brälin, näe man lldz!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es teV došu sešas kreklas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas sešas rakstitas."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Es nevaru, es neiet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man galvinu gaužam säp."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gulu, gulu, miegs nenäk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakš kuplu lagzdu krüm.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Atnäk mana ml}a brüte:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Celies, brudgan, näe man lldz!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es teV došu sešas bucas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas sešas saldas büs."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— „Nu es varu, nu es ietu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man galvinu vairs nesäp."</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meitin gäja uz avota,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zaja krüzit roka.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Preti näca jauni puiši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasit meitai zaja krüzit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meitin raud pee savas krüzit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Krüzit, tu man zala krüzit!"</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiši meitai muižus sola, —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meitai muižu nevajag,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meitin raud pee savas krüzit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Krüzit, tu man zaja krüzit!"</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiši meitai puišu sola —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meitai puišu (!) gan vajag:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Lai vilks sper to za}a krüzit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es pie puišiem pieturesies</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neiku külda kabaL jür!" ka pie zelta gabalin!"</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie vejini püš, tie salmini danco,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta koša meitina gauži ra'ud.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Neraudi, meitina, neserojies,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gan velaki mu'ms viss labaki</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Piec simtus dälderus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man mämin, dildildam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Teie, lai vinš jäj pro j am,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man meitin, dildildam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tukstošus dälderus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man mämin, di'ldildam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Teie, lai vinš näk iekša,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man meitin, dildildam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu ienäk iekša,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dildildam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Jüs abi melni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dildildam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Gaspaž, näe uz mäjam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;kungs teV gaid!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Lai vinš gaid, lai vinš gaid,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;saki, gan es iešu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Bes šo dancin veL vien dancin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">V&gt;tad es ieš(u) uz mäjam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Gaspaž, näe uz mäjam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;kungs ir slims!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Lai vinš ir, lai vinš ir,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;saki, gan es iešu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Bez šo dancin veL vien dancin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;tad es ieš uz mäjam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Caspaž, näe uz mäjam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;kungs mirst nost!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Lai vinš mirst, lai vinš mirst,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;saki, gan es iešu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Bez šo dancin veL vien dancin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;tad es ieš uz mäjam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Gaspaž, näe uz mäjam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;kungs guL zärka!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Lai vinš gul, lai vins guj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;nu vairs ne ir jäiet.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;Ar šo dancin veL daudz</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;dancin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">&gt;iet mäjas, kad tlk.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Slinkis gāja lūkoties uz sievas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apsēdas ap lielas kuplas ievas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sten un, vaida, kauc un gaida,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad jau nu kāds atnāktu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Slinkis gāja lūkoties sev sievu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apsēdas apakš kuplas liepas:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šeit vinš vaida, sten un gaida,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaut jel kādu atrastu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Īt par laimi līgavina pate,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pate manas rokas nāca.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak tu dievin, šeit man sievin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pate manas rokas nāca.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Slinkis steidzas nu (~ tad) ar mundram kājam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tam vajaga vīram būt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas pēc māses pūru nāk:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pieci vīri, seši zirgi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nespēi pūru kustināt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Minam, minam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māsin pēdas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai māte neredz,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka gauži raud.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Taut dēl atsūte</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tapinat kumelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne iekš māses pūru vaid</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tapinat villainīt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Veriet vārtus lī galam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rādiet celu uz tautam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pūr ved, pūr ved,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kun tek pakale.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ka kunin netecēs</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kucens pūr dubane!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gauži raud man pūrin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam ar jost neapsien.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Raud, pūrip, uz tautam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam tas mani jaun apnēm.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ieiedams istaba,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">izskaite priežu griests:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">eik tautami priežu griests,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik man īstu bālelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Iesam, iesam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māminas meklēt!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dabujam māminu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar atslēgam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzslēdz, māmin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savs klēts durvs!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Slēdz, māmip, valam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savs klēts durvs!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mēs dosim naud</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neskaitidam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nevediet mūs māsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ja papriekšu nešaujat:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">daž lab laun dien</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māršas cel maline!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāc āre, mūs māsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no šo vecu skuju būd!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tai klētei skuju jumt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piebierst mūs villainīt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">škireties, rūmeties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">draviniek meitu ved!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Draviniek meitu ved,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vaska kurpes kājine,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zīdu svārki mugure.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gērt, cērt, bālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zobeni krustam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cērt vellu pušam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trim gabalam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gērt, cērt, bālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zobeni krustam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cērt mūsu māršam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sēdamu viet!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur ta meits māmalit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka neredz rotajam?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne ta mūs sēdane,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne nonēm villainīt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Metati, metati</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kabata maizi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">O jel, N. N., tav lielu muti —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žagat ieskrej, apmet rink!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nesēd. N. N, pret mūs logu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur mūsu puišiem šaujamu viet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur tevi šaus no priekšas uz augšu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no pakalinas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nesēd. N. N, svikeiio benki</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur tava kūsite pielipinas!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">O jel, N. N, tav biezu lūpu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pieo pāra pastal no viena lūp.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīlo tēv, mīlo māt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">glabait savu maizikost!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne mums zirgu, ne mums rat,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur mēs maizi glabasim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Svied zeme, svied zeme!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nav labs, nav labs!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nem savu pirmej</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vainadzin!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Taut dēl klētine</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bezdubane avotip,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iekrīt māss vainadzin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūžam roka nedabuj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pazūd man meit mūž,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pazūd bār vainadzin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu nonem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vainadzin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu gērb meitinu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sievinu drānas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tin autu gāle,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sit labu pliki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai klausa vīr,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai vīra māt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāc, mūs māsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meitins pulke,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nesen nonēm</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tav vainadzin!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meit mūž lab mūž,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to pavade dziedadam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Siev mūž bēdu mūž,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to uznem raudadam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Būt laimin man sacijs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kād mūž tautines,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vēl varet meit būt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">valkat bār vainadzin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tēv dzirnu ritināt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lesim jele raudzities,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas iekš māss pūr būs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai būs eimd, vai būs zek,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai būs liel miegmaõ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gan bij eimdi, gan bij zekes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tukš lauž valodin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Daudz mūs māsin ganos gāj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">daudz bij darijs sīks velš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tos cimdinus brālam dodi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam tie raksti ir sajaukti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam bālinš nevēle</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">garu skalu dedzināt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cimds, zekes vien dare,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vāc vīr domedam:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">būt meitin apcereis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">darīt balts villainīts.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Priekš māminas ganos gāj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">priekš bālina piegule.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māminš sole raib gov,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bālinš bēru kumelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es augdam neredze</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">brālam tādu kumelin:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">virs škilinu rinki griez,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">virs dālderi lecina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māte mani ta pamet</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka vistin sav cālin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gālinš skrien pulcine,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur būs manim vienam iet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Neizdal, mūs māsin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viss savs cimds, zeks!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko tu dosi dzīvodam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sav dubl bridejam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sav maiz arejam?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nebija lustigi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu tape lustig!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Taisies, bālin, uzdziru dzērt!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzer govi, dzer vērsi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzer labu laimi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzer labu ozoli ar bititem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(~ dzer labu mīligu dzīvošan)!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Projami, projami, peleki vilki!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Apēda mūs brālam piecgadu vērsi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aste vien atlike kanõaku tiesa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to pašu iedeve vakara brālam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vakara māsa piedirš dangu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vakara brālis izškipale.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Metati, metati pavaru naudu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man ari, man ari nosvila villainu stūre</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(~ Man ari, man ari nosvila puskūsite).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Projam, projam, nelūgti vieši!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas lūgti vieši, lai gul nakti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pöš, elš, kumelinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man jauns kumelinš!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kä es nepüš, kä es ne-elš:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man divi jäjajin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tam ar vajag vlram büt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas mäsai pec püra braue</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pieci vlri, seši zirgi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nespej püru kustinat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pieci zirgi, pieci vlri</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nespeja püru kustinat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu ir jäiet, nu ir jäiet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mäte dod skaist(ak)u villainit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Otras setas puiši lielijas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar trim zirgiem püru vest.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad es gäju, tad redzeju</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">klibu äzi ecejam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cik reiz mani ieraudzij,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik ar äzi krümirios.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puru vedu, puru vedu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kuna teka pakaja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ka ta kuna lai neteku —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kucens pura dibena.</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">3a. Pz Prinz — s. Nr. 372 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Verat värtus lidz galam vala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sütiet mäsas viru preti!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Iesimi, iesimi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mäminu meklet!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mämina nozuda</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar atslegam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a.Pz Prinz — s. Nr. 375 a.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak laime, ak laime,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to lielu laimi:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atradu mäminu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar atslegam.</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">2a. Pz Prinz — s. Nr. 376 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Näe äre, müsu masin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no to läcu lamatin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai nekera lacenin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai neplesa villainit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Näe äre, müsu mäsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no ta veca skuja büd,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai nebirst villainlt</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar tam skuju akotam.</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">2a. Pz Prinz — s. Nr. 381 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nedoma, müs mäsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka büs tava želotaj, —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">büs taV matu plesejin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">büs taV asru lejejin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Šau, bälin, cert zoben,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai skaugi pazudas!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Daža laba launa diena</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mäsu ceja malina!</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">3a. Pz Prinz — s. Nr. 380 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cert, certu, bälinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zobenu krustu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cert skaugi pušam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trlm gabalam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1a. Škiraties, rūmaties, puki vedu istabāi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Škiraties, rümaties, puki vedu istabāi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cinaina, celmaina taut istabina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ciijaina, celmaina, taut istabina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gan musu käjinas salidzinase,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gan mūsu kājinas salidzinase.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Škiraties, rūmaties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puki ved istaba</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar visiem zarinam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cīnmais(!), celmais(!)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">taut istabina —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gan mūsu kājinas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">salīdzinas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Škiraties, dalaties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puku ved istaba,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puku ved istaba</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar visiem zariniem!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cik istabai verbalki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik daudz müsu bälini.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai bälin vienu nemtu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kadu paši gribedam!</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">3a. Pz Prinz — s. Nr. 374 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sed nu, müs mäsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">te tava vieta —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">te sed tavs ara j ins,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tavas maizes devejinš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nesed, müsu mäsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur tavs küsitis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz pikain benki:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pielipinäs.</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">Pz Prinz — s. Nr. 389 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nesedi, meitina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz svika benki:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur tavu küsiti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pielipinäs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nesēd, mūs māsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pret mūsu logu:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur mūsu puišami</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šaujama viet.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šaus tevi no priekš</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un no pakalin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nesēd, mūs bālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz caura benki:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaks (~ runcs) tavu kuliti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">izkibinās,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kibinās āra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas glabas iekša.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nesēdi, puisit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz caura benka:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur tavu pimsiti (~ pimpinu)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nogriezt var.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīli lūdzu, saimeniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">priekš man pupas nestādit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man pašam pupas auga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zirninš pupu galina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur, māmin, es sēdeš?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">—Paša rindas galina:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nāks laimin, nems no gala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne no vidus lasidams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Liela rinda sasēduši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">diženie, raženie:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur, māmina, es sēdešu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es bij tāda neraža?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Sēd, meitin, rindina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">paša rindas galina:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nāks laimina, nems no gala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne no vidu lasidam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jauns ar jaunu sēž pie galda,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viniem piens un medu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tā kā rozes zied,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vec ar vecu aizkrāsni</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cīkst kā rūgta nāve,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viniem skābi kāposti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko es dzied ar sausu rīkli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad slapinas, vairak skanas!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko es dzied ar sausu rīkli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad slapinas, vairak skanas!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur tu nēmi, mūsu brālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik raž́anu līgavin?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Te pat mūsu ciemina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visu lauž́u vainojam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur nēmi, man brāliti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik skaistu brūti?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Te pat ciemina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visu laužu vainojam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nava labi, nava labi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">paša ciema nemt sev līgav:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">katru rītu, vakaru</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skrien pie māti sūdzeties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skrien pie māti sūdzeties</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un vel basam kājam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Paskaties, bālelinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas tev sēž blakus!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mātes meit ar brūnam acim</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sēž bralitim blakus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Paskaties, bālelinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas tev sēž blakus!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mātes meit ar brūnam acim</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sēž bralitim blakus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sen dzirdeju, nu redzeju</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to lielu tēvu dēlu:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vieni paši brūni svārki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie tēvam, tie dēlam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie tēvam baznica,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie dēlam pie meitam ieš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sen dzirde(ju), nu redzeju</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to teicam tēvu dēl</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cīkst tev kauli staigajot,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">klab tev zobi runajot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Liec, mammin, jaunas kājas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie to vecu pakalin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai tu vari aptecet</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savu slinku vedeklin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trīs gadinus kaliinaj</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ošu vāli aizkrāsne:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad es iešu tautinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad velešu vīra māti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Diženi, raženi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lācu ved istaba.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai bagats, kas bagats,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs puisis visbagats:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piecas vārpas tam uzauga</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viena salma galina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tai pašai ciemina</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piecas maukas barojamas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai bij grēeigs, kas bij grēeigs —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meita liela grēcniece:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne ta svina svētu dienu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne piektaju vakarin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puisis bez prāta, cirvis bez kāta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">stāv pie priedes pieslietas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vectēvs ieliek eirvim kātu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bet kas ieliks puišam prātu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiši, puiši, pundariši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zirgi rudzu rugaja!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mes meišinas ka liepinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs gosninas āblina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Voi jelle, mūs bālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tav plate mute:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žagata ieskrēja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apmets rinke.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Uja, jauna meit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tavu platu muti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žagata ieskreja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apmeta rinki!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Pavasar izveda</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">devinus bērnus.)</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">4a. Pz Prinz — s. Nr. 387 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tautu dēl, bullu pier,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaidij mani uzaugam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai tu, bulli, neredzei,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ar tevim līdz aug?!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Veepuis, bulla piera</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaida manim uzaugam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai tu, bulli, neredzēju,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ar tevim līdzi aug,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas pūrin locidama</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz tevi gaidija?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nav vērts, nav vērts</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīram vecu sievu precet:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dienu rājas, nakti pirž,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīram traku galvu tais.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nava vērts, nav(a) vērts</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīram vecu sievu nemt (~ jemt):</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">diena sirdi, nakti pirdi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīram dullu galvu tais.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vecas meitas riekstes gāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pakal gāja vor-vor-vor.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tas nav labi, tas nav labi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka ta dzirnav istabe:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meita gāja vilnľ?) apkērt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">noker puišam paut(u)s (ciet).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko, puisiti, tu lielijies,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka tev pulku drēbes ir,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skrandas tevim mugura!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visas tavas skrandas dreb</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar meitämi runadams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es negribu ar tevi runat,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu, lepnais ciema puisis:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas tavas skrandas dreb,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar meitam runadams!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko jūs lielat, ciema puiši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nav iums bikses, zābaki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tikai vecas pastalas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vecas garas paltrakas!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lūž́u puiši, nieka puiši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne pazina tīrumin —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pavardai miežus sēja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par tīrumu domadams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko jūs lielat, ciema puiši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas gan jūs nepazīst:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pavardi jūs miežus sējat,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">domaj, lielais līdums tas!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko tu lielies, ciema puisi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad tu ciemu nepazīsti:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ugunskura miežus sēji,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">domaj lielu lauku esam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne mūsu vaina</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kāzami vaina!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šovakar, šovakar</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs brālam kāzas dzer.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak ēdej, ak ēdej,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apēda mūs brālam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piec gad(u) vec vērsi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aste vien atlikas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kancaka tiesai.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Edati, rijati,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nesāši laudis.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Apēda mūs brālam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piec gadu vērsi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Aste vien atlika</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kancaka tiesa.</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">Pz Prinz — s. Nr. 406 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labs tēvs, laba māt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">glaba savu maizi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne mūsu zirgi, ne mūsu rati,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur maizi glabat.</V>
'.
WARNING:root:Pattern '<L>(.*)</L>' does not match string '<L lang="lav">2a. Pz Prinz — s. Nr. 390 a.</L>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Paldies dievam, dievinam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu ir vakarini notureti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dod, dievinš, veselibu kājam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka var brokast izlūkties.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Augsti vieši manim nāks,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko es vinus mielošu?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viena paša ratu ula</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">runca pautus piesālit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Garam, nu garam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">slakteru zel(li)!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mūs sēta nevaid</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ālavas govis.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Turiesi, māsina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">līdz melnu zemi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nedodi tautinam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savu vainadzin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas zudis šovakar,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas zudis visu mūž —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zudis tavas meitas dienas (~ mūž),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tava boru vainadzin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Liec mici galva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sit labu pliki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai klausa vīru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai vīru(!) māt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Brudgana klēti dzilais avots,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam laipas pāri nav.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur iekrita brūtes kronis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko mūž́am nedabus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nekustini māsu krēslu:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur trīs sudrab bikeriš —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viena vīns, otra medus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">reša gaužas asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzer, māsinu, vīn ar medu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nedzer gauž́as asaras —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gauž́as asaras nāk paši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie slikta vīra dzīvodams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāc, nāc, bālini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka mīli lūdzu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savami brālami</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uzdzeru dzērt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāc, brālin, nāc, brālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uzdzerus dzert!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lei, mūsu māršina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pilnaju glāzi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzer, bālini, ko dzerdami,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūku, āzi vien nedzer:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūka raka, āzis lēca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māsa nevar noganit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzer, dzer, brālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs gārdu alu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs gārdu alu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un mete naudu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kac, kac, bālini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kac kab(a)te!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kac labu apalu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sudrabu naud!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kac, kacu, brālinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kac kabata,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kac labu apalu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sudrabu naudu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Metat zeltu, sudrabinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">varu vienu nemetat!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">To jūs paši gan ziniet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas būs varu metejam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tas būs varu metejam:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kuliti mālus grūst.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dukati, dalderi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jaunvīra nauda,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šilingi, vērdini</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ubagu nauda.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko tur jodu izkacas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka ne vaid ielikuš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viens pats grasitis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">maks(!) dibena.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">To pašu grabana</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">līdz gailu laiku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Brālitis tā meta</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā nabagam(a).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ej, māsin, nama,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dal nabagam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Paldies, bālini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par sudrabiti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bāliši(!) ta mite(!)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka īstai(!) brālit(!).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Paldies, mūs brālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par sudrabit!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ej, māsin, tirgu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pērc labu govi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad nokrita dzelžu stīp,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad izbirst sivenin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mūs(u) māsinai kāzas dzēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">siveni azote.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad atnēmu stīpu nost,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sivenini izbira.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sīvi dūmi nama bij(a),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vel jo sīvi istaba.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sīvis bija tautu dēls,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vel jo sīva vīra māte.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es guldinu gailiti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sav gultinu kājgala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai no rīta gailis cel(a)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neka sīva vīra māte:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gailis cel dziedadam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīra māte rājedam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu nāks, nu nāks</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs viešiem grūtie laiki:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pavaru naudu jasamaksa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Metati, metati</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pavaru naudu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Metati, metati</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pavara naudu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es ari, es ari</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">brudgana māsa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man ari, man ari</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Metati, metati</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pavaru naudu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man ari nosvila</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pus lindracinš (~ kūsitis).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Iesim, iesimi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie bagatiem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur kādu kapeki</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mums uzmetis.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Paldies, brālin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa(r) sudrabit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">7a. Metati, metati</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pavara naudu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es brūtes māsa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man daudz rūpes.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man nodega priekšautinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">caurums ar svārkos.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Metat zeltu, sudrabip,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">varu vienu nemetat!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Atpakal, atpakab,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nelūgtie vieši!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Neiešu, neiešu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">projam bez kukul.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad kāzas beidzas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad vajag kukul.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es gan protu izdancot</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visus vācu dancus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tikai es vien neprotu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka krievu kazaku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Divi žīdi, resna Trīn(a),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas par vieglu (~ skaistu) dancošan!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Divi žīdi, resna Trīn,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta ta viegla dancošan.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cīcs kažoks, caurais zābaks,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lec pa pagrab rācin zagt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cīťž kažoks, šauri zābak,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet uz pagrab rācin zagt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">4a. Ciecs kažoks burkin zog,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zvērbel Kīcs ar Kalku Cunc,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie div kopa burkin zog,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lībes mazais kuēeriš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas tos burkins projam ved.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Lāž un žonak, Lekš un Polman,:,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jaun-Rocam, Vec-Rocam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jauns-Tamst, Vec-Tamst,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gor-gor-gorkst!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cinku, cinku, grabu, grab, cela - vīra ragutin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie nešinku, tie negrab, tie radzini sasaluš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu ir slikti, nu ir slikti:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūka puišus nokodis!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta bij puišu paša vaina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam lien cūku midzeni.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu tik riktig, nu tik riktig,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vec Pric iet pie meitam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trādirīdi lip-lip-lip (~ vecais tēvs),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tas celš pie meitam iet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Gar tiem zirniem, gar tiem pupiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gar tiem kungu rāciem(!).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trādirīdam akmin spic,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tas celš pie meitam iet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Gar tiem kungu rāciniem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un gar kungu zirniniem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trādirīdam akal špic,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tas celš pie meitam iet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trādirīdi akmen špic,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trādarīdi latišok,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tas celš pie meitam iet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Caur pupinam, caur zirniem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">caur gatvi pagalmi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trādirīdi lip-lip-lip,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tas celš uz meitam iet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gar tiem pupam, gar to nabu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un gar peža malinu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tūl Alvīn. Vecmuiž laud,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gūtman Kristīn, Vecmuiž dēl,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pinin Līn un Eichental,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pīlberg Kristīn, Smilzin Ans.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Pinin Līn un Dundags skrīvers,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie div kopā turējās.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai vinš stāv, lai vinš stāv,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jūlin krita grāvi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nem to kekš, nem to kekš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">velc to Jūlin āra!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Latištū, latištū,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jūl(e) krite grāve!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīle puiš, jem to kekš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">velk to Jūlin āre!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak tu traka pilsētniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tu danco krakojak —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">resnas ciskas, melnas zekes</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un ta īsa lindracin!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sasmak deg,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žīd brēc.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai vinš deg,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es tik danco.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zīds (~ žīdin) brēc —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sasmag(a) deg.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es tik danco,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai tik deg.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiši, meitas, auniet kājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iesim laukus apskatīt!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lāci miežus apēduši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">salmi vien altikuši.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Vecas meitas sēd uz sēt, sēd uz sēt, sēd uz sēt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaid, lai puiši paliek lēt, paliek lēt, paliek lēt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiši lēti nepaliks, nepaliks, nepaliks,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meitas vecas gan paliks, gan paliks, gan paliks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Tas vecas meitas sēž uz sēt, sēž uz sēt, sēž uz sēt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un gaid, lai puiši paliek lēt, paliek lēt, paliek lēt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie puiši lēti nepaliek, nepaliek, nepaliek,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam meitam vecam japaliek, japaliek, japaliek.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Veci puiši sēd uz sēt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaid, lai meitas paliek lēt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meitas lēti nepaliks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko tēs raudat, jaunas meitas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gan jūs vīru dabusiet!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es ne nieku nebēdaj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaut gan puiši dusmojas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pieci seši mani prec,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vel devini lūkojas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Maza-Käpu veca Llze,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tä ir Indrik mila siev.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pipar virci, lozbar laps,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie ir vis rekname,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">laiva ir pagalam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak tu vecais prūsu cūka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tu gāj Vāczeme!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dod man (~ nu) ēsti, dod man dzērti —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aiju, aiju...</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mana veca sievas māt</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar tām līkam kājam —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">septin gadus elle bijis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vakar pārnāc mājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ahh-ū, jandal-ū,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tā ka veca šūle:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zilas bikses, sarkans kamzols,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pieci uti kabata!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tūdaliń, tagadiń,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pastalnieki dancõ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cits ar vīzem, cits ar zekem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">eits ar basam kājam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tūdaliń, tagadiń</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cits ar vīzem, eits ar zekem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">eits ar basam kājam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Veckungs, jaunskungs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nāc istabe dancot!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar ko tad dancosi —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kurpes, zekes noplīsušas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tīlipu, tālipu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ved mani dancot —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es biju (~ esmu) brūte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">baltas zekes kāja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas dzer alus, tam aug mieži</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neuzārta druviniem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas nedzeru, tam neaugu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne uz ārta druviniem!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Svētu rītu sajājuši (~ sanā.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: jauni puiši brokasta. :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Tie dzer alu, tie dzer vīnu, :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: dod tai pašai meitas mātei (~ uz māmina veselib).:,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Dzer, memminu, nebēdaja,:,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: vai dos meitu (~ meitin), vai nedošu. :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Ziemu braukt ar sirmiem zirgiem :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: mājas daila līgava. :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja nedošu(!) meitinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žēluma nomiruši(!) (~ žēlo manu mīlestibu),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ziemu brauc ar sirmiem zirgiem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mājas gudra (~ daila) līgava.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pūt vējinu, dzen laivinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aizdzen mani Kurzemē.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kurzemniece man solija</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sav meitinu malejin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Solit sola, bet nedeva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sauc man lielu dzērajin(!).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sauc man lielu dzērejinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lielu kumel skrējeiin</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(~ kumelinu skrējeiin).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kuru krogu es izdzēru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam noskrēiu kumelin?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pats par savu naudu dzēru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pats skrei savu kumelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāks rudenis, nemšu sievu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lūgšu tevis vedibās.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzērsim kāzas trīs dieninas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai dancoja panāksnieks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:: Lustig dzīvošan,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai tālu skan, lai tālu skan! :</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:. Kur nemsim tādas istabas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur dzērsim kāzas lustigas (~ krustības)? :</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„. Kur nemsim tādu vanninu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur mazgāt mazu Anninu? :</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzereipuiss bēdejas:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur gulešu nakti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai pie priedes, vai pie egles,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai pie mātes meitas?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne pie priedes, ne pie egles,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne pie mātes meitas —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur vinš cela pakrita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur guleja nakti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Akmens bija spilventinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">duble (~ dubli) paladzinš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man ir mājas tāda sieva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ar visiem pakšiem rājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man ir tāda sieva mājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ar visiem pakšiem rājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man ir tāda sievin mājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ar visiem pakšiem rājas —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pasarg dievs, pasarg dievs!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak mīla brandvīn butul,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas dara priecigu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas dara sārkan vaigu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un pliku pakalu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak kaut jel mūsu zeme būtu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">brandvīns(!) ezerinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es peldeju tur iekša</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka mazais asarinš!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak dārga (~ mīla) pudelite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas mani prieceja!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad jūra brandvīns būt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es labprāt tur peldetu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Se, pizdin, vasarsvētki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaide pats par jānem!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pises, meitin, ko tu gaid,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai tu sav nāvi gaid?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Atnāks nāve, nokos gāl,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tārpi tevi rubinas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kā es māk, tā es dzied:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lekš Pēter ō, Lekš Pēter ō,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neker man ciet, neker man ciet!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vecais Taizels iet ikdienas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Irbes kroga alus dzērt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">O vels, o vels, vecs Taizels grāve!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Anna, Anna, Tiľa meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nāc pie Lōram Pēteri.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pēteram ir brūni svārki,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Anna mellu villane.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Anna Pēter(i) ielaidūsi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">silineja irbu šaut.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šāvu irbu, šāvu mednu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nošāv raibu žagatu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Divu dalu pats apēdu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trešu deva kundzinam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Doktars rājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vezbergs nestāv mājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lōdan voľľid nēľa jalgõ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nabagam sāp kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēca, taisa tuo kūra durra cieta</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un irra beigta lieta.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Sīmam gan vel rakstus lasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kūkinam tad pakaus kasa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi laudis ta vien sauka:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pitragniekiem (~ mazgruntniekiem)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tūti lauka.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vec-žumbars uz notem spēle,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jaun-žumbars to nesaprot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi laudis usW.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Vec-žumbars uz notim spēle,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jaun-žumbars to nesaprot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi laudis tā vien sauka:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Pitradzniekiem tūti laukā!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sīms tad lasa „Dienas Lapuʼ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dēlnieks vinu sauk(!) par traku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Otam bērnu skaits ir liels,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nital saka: „Man tas nieks!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kurgat brauc ar zirgiem ašiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kūkinš pakausi sev kas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Randam bikses nokrist taisās,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Krogam naudas maisi raisas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Laulam jāskrien gajais celš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rūš aiz pakšiem klusam smēj..</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jaunciemniekiem grūti klājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sīkragnieki celas kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Maz-Irbnieki lasīt mācas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Košradzniekiem basas kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi laudis tā vien sauka:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Lieljūrniekiem (~ Dižjūrniekiem) tūti laukā!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pitradznieki malku skalda,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saunagnieks par kugiem valda.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vaid(a)nieki turas līdz,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neiūt tie, kad vadi plīst.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi laudis usw.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sīkragnieki alu prasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Maz-Irbnieki aktis lasa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Košradzniekiem kažoks plīst,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pitradznieki dusmās trīc.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saunagnieki žogus taisa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vaidniekiem tad acis raisas:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saunagnieces precēt taisas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">6a. El pel, brauc uz el,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārved lupat lel!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Annin kannin kroga dzēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasit kannin, nobuõoja Anninu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Anni-kanni kroga dzēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kestar kēv meže brauc.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Alus kannu kroga dzēru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kester kēvi meža braucu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Anna vanna, kakis vanne,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tikmer spārdies, kamer ār.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Annin kannin brauc pa led,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasit kannin, izgāž́ med.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Edin ledin leo par ledin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasit podin, izgāž́ medin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saules meitai kāzas dzer,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pērkons jāja vedibas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šurpu jājot, projam jājot,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasper zelta ozolin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saules meitai kāzas dzer</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pērkons jāja vedibas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šurpu jäjot, projam jäjot,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zibens škīla uguntin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Man bij viena balta pupa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nezineja, kur stāditu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Balta smilkš kalnina iestādeja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur uzauga gara pupa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad nolaida dieva dēls</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">baita pupa stiebarina</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānu bērnus apraudzit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Tur noauga gara pupa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad nokāpa dieva dēli</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gar pupinas stiebrinu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāna bērnus apraudzit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai dievin, vai dievin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur es dievam acūden dab?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, meitinu, tec, meitinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie treša avotina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai dievin, vai dievin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur ir dievam acūdens.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Atnes dievam acūden</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apzeltita blodina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Spīde ūdens blode</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka debes zvaigzne.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dievs svēti Kurzemi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs maizes zemiti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur mēs dzīvojam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāciet, bērni, šurp ar bariem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skataties (!) uz ozoliem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Redziet pie tiem kupliem zariem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Apsaloms ir paskāris.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māc(a)ities visi klāt</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tēvu, mātu godinat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sakarija, Lizabete,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abi dievabijig.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak cik jauki, bet kā reti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīrs ar sievu vienadi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bērninš es vai tukšs no prieka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne man visur laime zied?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vala spēleties ar niekiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">klausities, kā putni dzied.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māte mani mazinai</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lakstigalu šuple lika,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai es tāpat dziesmas dziedu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā dziedaja lakstigal.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dziedot dzimu, dziedot augu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dziedot gribu nodzīvot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Labak skaistas dziesmas dziedu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neka niekus runaju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Kam raudi tik ilgi pie krasta?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sev arāju izvēlējies!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad nebūs tev skiršanas nasta:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas projam no tevis neies.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">o jūrniekam netīk šie krasti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam tāluma jadodas ir,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to aicina milzigie masti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik ūdens tam prieku pieškir,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu tad lai mēs izplēšam zēgles,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka varam mēs mudigi braukt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ja liktens mums briesmas būs vēleis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un jūra sāks dusmigi kaukt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur redzu es mīligas nāras</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar dievu, pēc tevim man žēl!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sūds un dūmi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">miglains laiks (~ gaiss),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sievas sūdsmaks</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nāves tvaiks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Iet pa mež —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad iet pa ež ~ pež.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Iet pa taku —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saue par traku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Iet pa cel —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad iet pa tel.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pelit brauc, ratin ēīkst,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atved bērnam miedzin —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">caur vārtiem, caur krāsnip,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">caur šūplu pagalvin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gul, mans mazais cālits, gul,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nezin, kas rīta tevi sagaidis.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vel māte par tevi nomoda stāv</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un skatas, lai saldi tu dusetu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Skanigi dziedaja mazais gailitis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai no rltiem tu agri pieceltos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bernu pienäkum saue,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bernam agri jäeejas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Mazinš biju, neredzeja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad nomiru (!) tēs un māt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ganes gāju, es atradu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur gul mans tēs, māmuliš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Balta smilkti kalnineja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakš zala veleni(z).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gēlies augša, man tēs un māti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es pacelšu velenin(u).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ks tev teikšu raudadama,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko man dara sveša māt(e).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Plikus (plikes) eirtu, matus plēsu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kājam speru pabenki.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pēdigi vel mani raida</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie āboliem rīkstes griezt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ks piespiedu pie ābolin</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā pie savas māmulin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pirst ābolam balti ziedi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">birst man gauž́as asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mazinš biju, neredzeju,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad nomira tē(v)s, māmin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu uzgāju ganidama,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur guleja tēs, māmin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Balta smilšu kalnineji,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakš zalam velenēm.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cēlies augša, tēvs, māmina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es pacelšu velenes.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es tev teikšu raudadama,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko man dara sveša māt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte sūtija</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie ābeles rīkstes griest.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pie ābeles es piestājos</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā pie savas māminas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Abelei birst balti ziedi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man birst gauž́as asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Uz piegulu nu lustigi mums laiāi kleperos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz tuvu plavu mudigi nu nemsim lēgeru.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad guni uztaisisim un (zēni) kopa sanāksim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad taurus mēs uztaisisim un kopa (zēni) sanāksim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāna bērni nāk nosaluši (~ basam kājam),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pilna (~ pilla) nasta mugare (~ jāna zal),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māte dod raibem gojam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tēs (dod) sirmiem kumeliniem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāna tēvs, jāna tēvs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tu mums atnesi?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kājas vis ar pukem piln,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">galva ozol vainadzinš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lavakaru, rācin lauka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kādi ziedi rāeinami?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Zili ziedi, balti ziedi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tādi ziedi rācinami.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rīta rasa, auksta rasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rasa sala kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">še, meitina, zīžu drānu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasen savas kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rozes zied uz tām meitu galvam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dadži zied uz tiem puišu galvam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak tu vecais zemniek-bauris,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā tev jau ir sen pliks pauris!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tu jau tiec kā cūka kauta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">āda tev par acim rauta.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lupatas un skrandas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tās tavas bandas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">putra tev par kungi vandas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tautas dēlu māmulite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atdod manu vainadzinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es atdotu tavu dēla,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kuru diena gribedams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tavs dēls nemācēja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūkai sili pataisit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Diži puiši noganei</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man maz aplaucin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pie alus galda sēdeja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">daudz jūras brauceji.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie savas glāzes tukšoja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un tērzas līksmigi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bet viens starp viniem sēdeja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar sēiu skumigu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam škiršanas no mīlaka</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lauž́ vinam sirsninu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">To vina biedri nezina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie smei un līksmojas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jo kugis stāv uz enkures,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz projam braukšanu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāc, mīla, līdz uz jūrmalu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur es tev zvērešu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es līdz beidzmam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">stundinam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik tev vien mīlešu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tik uzticiga palieei</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu manim, Annina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un netur citu mīlaku,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur manis piemina!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu tad ar dievu, meitina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu asaras vēl smaid,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar dievu, dārga mīlaka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jo biedri manis gaid!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad rīta vēsma sveicienus</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no tālam zemem nes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un vilnu ēali stāsta tev,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">eik dārga tu man es,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">daudz kokiem galus lauž</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un drīz no celmiem atvases</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jau asnus āra sprauž,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bet manas laimes atvases</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz jūras vilniem stāv</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un manas jaukas ceribas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">var drīz tur atrast nāv.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jel rimsties vienreiz, meitina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nem šito gredzenu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nāc man pie krūts vēl,dārgaka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un dodi butinu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1. Tur klosteri aiz melniem mūriem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vien skaista meitin dievu lūdz.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta lūdz par kādu karavīru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas kara grūti ievainots.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2. Bij vakars vēls un viss bij klusu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vēl daba maiga miega dūs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tik slimnica starp augstiem mūriem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vēl kāda māsa dievu lūdz.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta lūdz par jaunu karavīru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas kara (~ cīna) grūti ievainots.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Te lēni kāds pie durvim klauve</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un ienāk skaista (~ balta) meitina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Klau, kur maza zīlite dzied</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">brālinei (!) namgale.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec māsinu lūkoties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kādu vēsti zīle nes.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zīle nesa tādu vēsti:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">brālam jāiet karina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, māsina, dārzina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">puško brālam cepuri,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sedlo bēro kumelip.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne caur vārtiem neizjāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nokrit brālam cepurit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Lūgšu, lūdzu, tēvs ar māti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pacel manu cepurit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēvs un māte nepacēla</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no ta liela žēluma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Lūgšu lūdzu, brāls un māsa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pacel manu cepurit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Brāls un māsa nepacēla</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no ta liela žēluma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas godiga mātes meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pacel manu cepurit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kumelitis gan atskrēja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bālelinš neatnāc.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad māte mazu šūpoja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad sauc par karavīr.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad zēns jau bija uzaudzis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no kungiem izredzets.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pats kungs tam zirgu seg:oja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar ťlint un zobeni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad aizsūt man uz karalauku</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pret nikniem ťrancuž́iem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur lodes skrien ka bitites,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas man var samaitat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad liek uz maziem vāgišiem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un ved uz lazareti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur lazaret modars gultu tais</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar mīkstiem spilveniem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trīs genrali, trīs doktari</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie manas gultas stāv.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lūdzu, mīlu gendrali,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jel rakstiet grāmatu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jel rakstiet vienu grāmatu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">priekš maniem vecakiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai tie nāk mani apraudzit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cik man ir jācieš grūt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jel rakstiet vienu grāmatu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">priekš manas mīlas brūtes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai atved zārku un palagu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">priekš manam augumam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vel mīla nebij atnāceis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad zēns bii nomiris.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ka sunu bedre iesvēda</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bez zārk un palagu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pie Daugavas tur tāli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur kara pērkons dūc,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visiem rozes dārza ziedei,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">manas rozes neziedeja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es kara (~ Ez karina) aiziedams</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atstāj māsin, šūpuli.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(No karina atnākdams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atrod lielu rakstitaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pavaicaju māminai,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ta tāda rakstitaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta, dēlina, tav māsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko atstāji šūpuli.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Lūgšu, lūdzu, man māsin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">raksti kara karodzin!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Raksti baltu vaj sārkan,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūž́am tevis neredzeš!)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Karavīri bēdejās</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">asinaina gaisma aust.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trīs lillijas, trīs lillijas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tās aug uz vienu kap.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Te nāk viens latviu karavīrs</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un noplūc tās.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Spēlēiu, dancoju visu cauru nakti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar vienu jaunu meitin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nebii spēle izspēleta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sāk ta gauži raudat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Klau, klau, kur pulkstens zvana,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dievs zin, kas miruse.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viena jauna meitin mir,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar grūtu slimibu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā meitin apgērbts tika.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1. Trīs priedites silinā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai manu vai,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas viena smuidrumina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai manu vai!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vienu eirtu, otra lūza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trešā līdzi loeījās.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māminai trīs meitinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas viena dailumina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vienu jēmu, otra nāca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trešā līdzi taisījās.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dod, māmina, to meitinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kura līdzi taisījā.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja nedosi to meitinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es nomiršu žēlabās.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur jūs mani glabasiet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žēlabās nomirušu?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rociet mani rožu dārzā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zem rozīšu saknitēm.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur izauga kupla liepa</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">deviniem žuburiem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Īk rītinu meitas nāca</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vainadzinus darināt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2. Trīs meitinas māminai,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai manu vai,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas vienu dailuminu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai manu vai!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vienu nēma miežu arajs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">otru jūras braucejinš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trešo, pašu pastariti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">svētu rītu bildinaju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trīs rozītes dārzinai,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas trijas izplaukušas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1. Līgo, laiva, uz ūdena, uz araia meitiuam!! Arajami skaistas meitas zēgelišu audējas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2. Līgo, laiva, uz ūdena,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz araja meitinam!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Arajam ir skaistas meitas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zēgelišu audejinas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viena auda, otra vērpa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">treša zīdu škitinaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dod, māmina, to meitinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas to zīdu škitinaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja nedosi tas meitinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es nomiršu žēlabas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur jūs mani glabasieti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žēlebas nomirušo.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur mēs tevi glabasim,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skaista rožu dārzina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur uzauga kupla liepa</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">deviniem žubariem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Īk svētdienas meitas nāca</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vainadzinus darināt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Novijušas vainadzinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aiziet Māras baznica.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māra prasa raudadama:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Kur meitinas tādu nem?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Rīga pirku, naudu devu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">elgavai kaldinaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Ko jūs, meitas, melojieti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tā ir puišu dvēselit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tā ir puišu dvēselite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žēlabas nomiruša.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">No rītinas agruma</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māsiš tee gar jūrmala.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zilas acis, sārkni vaigi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atdzeltene matine.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Ai, zveiniek, ai mīla zveiniecina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai neredzei mau brālin?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Ai, meitip, ai meitina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas gul jūras dibena!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2. Es kāp uz augstu kalnu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un skatos jūrina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es redz vien laivin peldam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur ir mans mīlais draugs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad piepeld vinš pie malas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad sāksim buõoties.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Ak meitip, tu gan smuka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaut tu tik bagats būt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">priekš manu augstu godu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu ir par nabagu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Ja es priekš tev par sliktu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad iešu klosteri,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad aiziešu uz kloster</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un likš par nonnu saukt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meita gāja uz avotu, uz avotu, uz avotu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Preti nāca jauni kungi, jauni kungi, sasit meitas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Meita raud pēc savas krūzes, savas krūzes: „Krūzit, manu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ūdens smelt, ūdens smelt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ūdens krūz, ūdens krūz.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zalu krūz, zalu krūz!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lozīt sēdii cietumnamā, gaťš laiks vinu moca, Bozīt sēdii</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cietumnamā, gagš laiks vinu moca.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Reiz dzīvoja (~ bija) div kēnina bērni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viens otru tie mīleja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dēľ platas ūdena straumes</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tiem grūti bij satikties.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trīs svecites princese aizdegv</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un tās uz loga stād,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai vinas mīlakam peldot</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam gaišu celu rād.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tur dzīvoja kāda nonne,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas vinus nīdeja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta aizgāja reiz tur slepen</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un sveces izdzēsa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bet prineis šam svecem (~ šim lampam) mirdzot</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">droš peldet iesāka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bet piepēži vinam dziestot,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas grima dziluma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Un princesei mīlako gaidot</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sirds loti ilgojas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Let lampas lūkot un atrod</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas visas nodzēstas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pie zveinieka vina nu steidzas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un mīli lūdza to.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad abi tie laivina dodas iekāp</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un princi meklēt sāk.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Neilgi pēc maza brīža</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">te vinu atrada.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dz to nu princese skatās</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar stīvam actinam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad lec ar mīlakas līki</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">plikšt‿jūras dziluma,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur vinus šo pašu dienu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neviens vairs atrada.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trīs jauni puiši no pilsētas nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar nama gaspaž́u runat tie sāk:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Gaspaža mīla, vai alus iums labs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai jūsu meitina sieva drīz taps?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Alus mans smekigs un gārds gan vel būs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bet mana meitina glabata klūs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Celinieks no tāla svešuma</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">steidzas mājas mīla tēvija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sirds tam krūtis pukst it priecigi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">redzot savu dārgu tēviju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta vinš iet pie kāda dārznieka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam ziedeja visskaistas pukites:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rozes, nelkes, liljes, vijoles,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">debess zilas neaizmirstules.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Daila, jauna, skaista dārzniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">liljem līdziga nobāluse,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dārza skaistas pukes noplūkt iet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">grib priekš celinieka puški siet.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gelinieks ka stabs no brīnumiem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">skatas, ka ši pukes plūc un sien.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Asaras birst par vaigiem aumuliem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">asaras birst uz pukem noplūktam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sakiet, skaista daila dārzniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kādēl esiet jūs tik bēdiga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai iums žēl šis skaistas pukites,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko priekš manim esiet plūkuš́as?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Ne, dēl pukitem es neraudu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">labprāt visas dēl iums noplūktu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Raudu tik pēc visumīlaka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas aizgāj tāla svešuma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dztieibu vinš man solija,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uztieibu līdz šim tureja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bet es, nelaimiga dārzniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uztieibu esmu lauzuse.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Lūdzu, daila skaista dārzniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dodiet man šo puku puškiti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jo tur virsu jūsu asaras,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas ka pērles mirdz un laist(ij)as.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar šo puški došos tāluma,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tevi paturešu piemina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pasaule tad apkārt blandišos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kamēr dzestrais kaps man mieru dos.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jods lai parauj to,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka ta jādzīvo.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko līdz bramoties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko līdz lepoties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu sirdi mieru nav.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu kas ta tev ta moca</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka kāds negants jods?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">~ Man piekrāpu smuka meitina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man pievilu man līgava.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dies lai soda tev, tu viltniece,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kamdēl tu mani piekrāpa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tumšas dieninas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaišas naksninas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kādam saimniekam pie mājam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">krūmos dzivoi ēigani.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saimnieks sola saviem puišiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pus stop šnabu dāvedams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai tos ēigains nu ar godu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no krūmiem āre dzen.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pirmais puisis jem to tauru,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet pa mežu baurodam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">0trais puisis lēnam soliem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet pa mežu zarus lauzt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Trešais puisis taisniem soliem</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet pie ēigainiem:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Klausies, brāli, ko es saku,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saimniekam ir bullis traks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Durvis gāž́ no engem āre,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet par mežu baurodams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu tik ēigain vis uz rinde</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jūdz un brauc, ka brikšt un brakšt.</V>
'.
csvstack data/work/skvr/poems.csv data/work/erab/poems.csv data/work/jr/poems.csv data/work/kr/poems.csv data/work/vldl/poems.csv > csvs/poems.csv
csvcut -c poem_id,collector_id data/work/skvr/meta.csv > data/work/skvr/poem_collector.csv
csvcut -c poem_id,collector_id data/work/kr/meta.csv | csvgrep -c collector_id -r '^.+$' > data/work/kr/poem_collector.csv
csvcut -c poem_id,collector_id data/work/vldl/meta.csv | csvgrep -c collector_id -r '^.+$' > data/work/vldl/poem_collector.csv
csvstack data/work/skvr/poem_collector.csv data/work/erab/poem_collector.csv data/work/jr/poem_collector.csv data/work/kr/poem_collector.csv data/work/vldl/poem_collector.csv > csvs/poem_collector.csv
cp data/raw/skvr_poem_duplicates.csv csvs/poem_duplicates.csv
csvcut -c poem_id,place_id data/work/skvr/meta.csv > data/work/skvr/poem_place.csv
csvcut -c poem_id,place_id data/work/kr/meta.csv | csvgrep -c place_id -r '^.+$' > data/work/kr/poem_place.csv
csvcut -c poem_id,place_id data/work/vldl/meta.csv | csvgrep -c place_id -r '^.+$' > data/work/vldl/poem_place.csv
csvstack data/work/skvr/poem_place.csv data/work/erab/poem_place.csv data/work/jr/poem_place.csv data/work/kr/poem_place.csv data/work/vldl/poem_place.csv > csvs/poem_place.csv
csvcut -c poem_id,year data/work/skvr/meta.csv > data/work/skvr/poem_year.csv
csvcut -c poem_id,year data/work/kr/meta.csv | csvgrep -c year -r '^.+$' > data/work/kr/poem_year.csv
csvcut -c poem_id,year data/work/vldl/meta.csv | csvgrep -c year -r '^.+$' > data/work/vldl/poem_year.csv
csvstack data/work/skvr/poem_year.csv data/work/erab/poem_year.csv data/work/jr/poem_year.csv data/work/kr/poem_year.csv data/work/vldl/poem_year.csv > csvs/poem_year.csv
mkdir -p data/work/kr
( [ -f "data/raw/kr/kanteletar/poem_category.csv" ] \
  && cp data/raw/kr/kanteletar/poem_category.csv data/work/kr/poem_types.csv ) \
|| ( echo "poem_id,type_id,type_is_minor" > data/work/kr/poem_types.csv )
csvstack data/work/skvr/poem_types.csv data/work/erab/poem_types.csv data/work/kr/poem_types.csv > csvs/poem_types.csv
cp data/raw/polygon_to_place.csv csvs/polygon_to_place.csv
jq -r '.features[] | [.properties.id, .properties.place_id ] | @tsv'\
    csvs/counties.geojson \
| sed 's/$/\t1/' | csvformat -t -U 3 >> csvs/polygon_to_place.csv
jq -r '.features[] | [.properties.id,'\
'                    ( .properties.parish_place_ids | join(",") ) ] | @tsv'\
    csvs/counties.geojson \
| awk '{ gsub(",", "\n"$1",", $2); print $1","$2; }' \
| sed 's/$/,0/' >> csvs/polygon_to_place.csv
csvstack data/work/skvr/raw_meta.csv data/work/erab/raw_meta.csv data/work/jr/raw_meta.csv data/work/kr/raw_meta.csv data/work/vldl/raw_meta.csv > csvs/raw_meta.csv
csvstack data/work/skvr/refs.csv data/work/erab/refs.csv data/work/jr/refs.csv data/work/kr/refs.csv data/work/vldl/refs.csv > csvs/refs.csv
mkdir -p data/work/kr
( [ -f "data/raw/kr/kanteletar/categories.csv" ] \
  && cp data/raw/kr/kanteletar/categories.csv data/work/kr/types.csv ) \
|| ( echo "type_id,type_name,type_description,type_parent_id" > data/work/kr/types.csv )
csvstack data/work/skvr/types.csv data/work/erab/types.csv data/work/kr/types.csv \
| csvcut -c type_id,type_name,type_description,type_parent_id > csvs/types.csv
python3 code/add_type_links.py csvs/types.csv -t 0.7
csvstack data/work/skvr/verses.csv data/work/erab/verses.csv data/work/jr/verses.csv data/work/kr/verses.csv data/work/vldl/verses.csv > csvs/verses.csv
csvgrep -c verse_type -r "V" data/work/skvr/verses.csv \
| csvcut -c poem_id,pos,text \
| python3 code/clean_verses.py -c text > data/work/skvr/verses_cl.csv
csvgrep -c verse_type -r "V" data/work/erab/verses.csv \
| csvcut -c poem_id,pos,text \
| python3 code/clean_verses.py -c text > data/work/erab/verses_cl.csv
csvgrep -c verse_type -r "V" data/work/jr/verses.csv \
| csvcut -c poem_id,pos,text \
| python3 code/clean_verses.py -c text > data/work/jr/verses_cl.csv
csvgrep -c verse_type -r "V" data/work/kr/verses.csv \
| csvcut -c poem_id,pos,text \
| python3 code/clean_verses.py -c text > data/work/kr/verses_cl.csv
csvgrep -c verse_type -r "V" data/work/vldl/verses.csv \
| csvcut -c poem_id,pos,text \
| python3 code/clean_verses.py -c text > data/work/vldl/verses_cl.csv
csvstack data/work/skvr/verses_cl.csv data/work/erab/verses_cl.csv data/work/jr/verses_cl.csv data/work/kr/verses_cl.csv data/work/vldl/verses_cl.csv > csvs/verses_cl.csv
awk -F, 'NR == 1 { print "poem_id,pos,word_pos,text"; }'\
' NR > 1 { gsub(" +", " ", $3);'\
'         split($3, a, " ");'\
'         for (i in a) { print $1","$2","i","a[i]; } }'\
  data/work/skvr/verses_cl.csv > data/work/skvr/word_occ.csv
awk -F, 'NR == 1 { print "poem_id,pos,word_pos,text"; }'\
' NR > 1 { gsub(" +", " ", $3);'\
'         split($3, a, " ");'\
'         for (i in a) { print $1","$2","i","a[i]; } }'\
  data/work/erab/verses_cl.csv > data/work/erab/word_occ.csv
awk -F, 'NR == 1 { print "poem_id,pos,word_pos,text"; }'\
' NR > 1 { gsub(" +", " ", $3);'\
'         split($3, a, " ");'\
'         for (i in a) { print $1","$2","i","a[i]; } }'\
  data/work/jr/verses_cl.csv > data/work/jr/word_occ.csv
awk -F, 'NR == 1 { print "poem_id,pos,word_pos,text"; }'\
' NR > 1 { gsub(" +", " ", $3);'\
'         split($3, a, " ");'\
'         for (i in a) { print $1","$2","i","a[i]; } }'\
  data/work/kr/verses_cl.csv > data/work/kr/word_occ.csv
awk -F, 'NR == 1 { print "poem_id,pos,word_pos,text"; }'\
' NR > 1 { gsub(" +", " ", $3);'\
'         split($3, a, " ");'\
'         for (i in a) { print $1","$2","i","a[i]; } }'\
  data/work/vldl/verses_cl.csv > data/work/vldl/word_occ.csv
csvstack data/work/skvr/word_occ.csv data/work/erab/word_occ.csv data/work/jr/word_occ.csv data/work/kr/word_occ.csv data/work/vldl/word_occ.csv > csvs/word_occ.csv
