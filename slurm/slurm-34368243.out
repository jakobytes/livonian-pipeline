'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai meitas nedabu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saim(e)niece cisku kasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nedod galu kekniekam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vai tu kasi, vai nekasi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">galu tāpat jaiedod.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Klib tavi jērini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">klib aitinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">klib tavi kazleni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">klib āziši!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lec tavi jērini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lec tavi aitini,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lec tavi kazleni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lee (tavi) āziši.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec. Marin, stalline raudzit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gojam piedzimis maz gojiš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">raib gojiš ar garu astu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar baltem kājem.</V>
'.
