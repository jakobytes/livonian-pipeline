'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viens mazs pulkstentinš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">divas vistinas uz gaʼlda.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kāpies tur, kāpies šur,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kāpies uz galda stūri.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu sala, nu sala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nu stipri sala.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu sala jūrina</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">līdz dibenam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nu var aizbraukt</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kensberga ciema.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">selli urn ka kuskōs?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīleja māmina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">laiž bērnus iekša:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piemīza kurpes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasala kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lūdzams, māmip,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">laiž bērns iekša:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piemīzu kurps,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasalu kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mila māmin,.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">laiž bērns iekša!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Keknieku bērninam</V>
'.
