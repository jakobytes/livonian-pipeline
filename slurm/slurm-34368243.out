'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">circeņi aizkrāsne dzied.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Eiai žūžu, maz meitiņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">circenits dzied aizkrāsne,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bērniņš dzied šūpole.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Katel loks,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">silkš un apavš!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar visiem ratiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ragiem, apaušiem. </V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Žīds nāk, žīds nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pauns mugre, pauns mugre.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ponti-tūri, ponti-tūri,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kalti-tūri, kalti-tūri.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Žīdi (!) rati sūdi (!) rati,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man pašámi kalti rati.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tavi rati sūdu rati,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mani rati kungu rati.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Žīdam bārda uta(!) pilla,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man ta kažok un ta villa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Žīdam bārzda utu pilla,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam ta kažok, tam ta villa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Līgo, līgo, memmiņ, mājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visi bērni gaidu(!):</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">citi sildes saule,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cit aiz vārtiem maule.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gul, mazs bērniņš, labu miegu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēvs gāja ciema padoma prasit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka var ceļa vīra nomuškot (~ nokaut ~ nonāvet).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Guli, mans cālis, guli!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēvs tevi sārga ar eņģeļiem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Guli ni līdz rītam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kamēr gaiļi dzied kikerigī!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Miega Maču mani precu (!),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa dangav staigadams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ne-ej projam, miegu Maču,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es jau tev gan gribes.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Miegu-Maču mani preca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa dangámi staigadams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Neej projam, Miegu-Maču,</V>
