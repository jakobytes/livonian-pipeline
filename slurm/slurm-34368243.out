'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">citi gani raudaja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzenis kala krustu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">līkaja bērze,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūka raka kapu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">augstaja kalna,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sīki mazi putniņi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pātarus skaitija,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaza kāpa debesis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dievam sūdzet.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viens gans nomira,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">citi gani apraudaja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaza raku kapu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzenes kalu krustu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kraukels apzvaneja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sīki mazi putniņi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">irbis(!) kāpu koka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gāju dievam sūdzet.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tivva-tovva uz žog,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">veca vārdna(!) už‿jumt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur tu teku, kur tu teku, man gailit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tik agraja rītiņa?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Teku ciema, teku ciema meitas celt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tiem nevaidu cēlejiņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Kur tu teci, kur tu teci, gailiti man,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no rītiņa agruma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Teku ciema, teku ciema meitas celt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam nevajg cēlejiņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ieteceju, ieteceju sētiņa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs reiziņus padziedaj:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Celies, mana, celies, mana līgaviņ (~ uzcelies, uzcelies, ciema meit),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tevim nevajg cēleji—.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">4a. Kur tu teci, kur tu teci, gailit man,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no rītiņas agruma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ciema teku, ciema teku</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ciemas meitas modinat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad ieteces, kad ieteces sēteņeja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad nodziedaja kikirigī!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Celat, meitas, celat, meitas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tautietš‿jāja sētiņeja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Atver vārtus, atver vārtus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ielaiž tautiņ sētiņeja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad pa vārtiem iejājas (!),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sirmais kumels nozviedzeja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelt iemaukti nožļirgsteja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">5a. Kur tu teci, kur tu teci, gailiti man(a),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no rītiņa agrumā, no rītiņa agrumā?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ciemā teku, ciemā teku meitas celt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meitam jāja precinieki, meitam jāja precinieki.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Aizteceju, aizteceju sētiņā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gailis trīs reizs nodziedaja:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">„Celies mana, celies mana līgaviņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tev atjāja preciniek(i).“</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Čigans savu, čigans savu čiganiet(i)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar pātagu džindžolej(a).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vāciets savu, vāciets savu vācieti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kreņģeli kaitinaj(a).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Latviets savu, latviets savu latvieti</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar buciņu skupstija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Čiganam ir maza melna,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vācietim ir tieva gara,,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">latvietim ir maza resna.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">a. Kur tu teci, kur tu teci, zilbikšit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no ritiņas, no ritiņas agruma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Teku ciema, teku ciema meitas celt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: priekš gailiša dziedašan. :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gailits brauca Rīga,</V>
'.
