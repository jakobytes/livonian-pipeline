WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2. Kas brie-di-mu, kas lā-ci-mu me-žā kā-ra šū-po-lit?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3. Lie-li vī-ri iz-au-gu-ši, ne-šu-po-ti, ne-lo-lot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Aia, žūžu, lāča bērni, aia žūžu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pinkainami kājiņam, žūžu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas briedemi, kas lāciemi (!)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meža kāra šūpoliti —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lieli vīri isauguši</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nešūpoti, neaukleti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Guli, guli, mazais bērniņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne tev tēva, ne māmiņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēvs aizgāja bites raudzit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māte ogas palasit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Būs man medus, būs man ogas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par bērniņa šūpošan.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mana balta māmuliņa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">balti mani audzinaja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">baltu kreklu apvilka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta šūpli guldija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gan jau māte zinaja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā grūt meitu ja-audze.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dažu nakti neguleja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man pie šūpļa sēdedama</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(ar apautam kājiņam).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kam tu, māte, auklus viji,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam šūpoli karinaj —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es būt liela isaugusi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nešūpota, neaukleta.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Čīra-čūra alutiņa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bika-beka kukuliņa!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Čirra-čorra alutiņu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bika-baka kukuliņu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Te tek peliņ :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">te tie pazud.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cep, cep kukliņu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pādamu nes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atradu gārdumiņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apēdu pats.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pač-pač kukliņ pādam nest.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Iešauju krāsni, izvelku āra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atradu gārdum —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apēdu pats: ņem-ņem-ņem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vāri, vāri peli putru (~ putriń)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šim dos, tam dos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam vienam nedos (~ mazam A. vismazak dos).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Utbung, krējumlaiž, gaŗmeitiņ, zeltnesej, mazs Ansits (~ Incitis).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">7a. Utbung, krējamlaiž, gares Indriķs, zeltnesis, mazansits.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Danci, danci, bomu niedr,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">katru dienu svētdiena.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dance, dance, bomspolit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">katru dienu svētdiena.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Žīdam bārzd, kazei bārzd,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abiem diviem spica bārzd.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur tu ietu, Māŗa meit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta slota paduse?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es ies Māŗam istab slauct,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māŗam nāk zelta vieši.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur tu iesi, Māra meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta slota paduse?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Iešu Mārai plānu mēsti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mārai nāk zelta vieši.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Maza meitiņ, kur tu iet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta slota paduse?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ta nav zelta slota,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta ir bēržu apakš zaʼrs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur tu iesi, Māŗas meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta slota paduse?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ta vis nava zelta slota,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta ir bērzu zemais zaʼrs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Krupu skuķis, kur tu braukse</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar tiem zelta ratiņiem?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Es kaitinu kungu dēlu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas uz mani noskatij.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Maz puiš, lukiņ (!) cepur,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tu iet?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es ieš kroga alus dzert,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar mazem meitem dancot.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ansis ēda un tik ēda,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">diezgan tam vien nebija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vēders bija tam ka bunga.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Čuņ-čuņ, kumelit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas man iedos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas sēde zelta krēslite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas man nedos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas sēd sūdu muldiņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māt man sūtij sietu prasit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko tu daris ar siet.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kukul ceps.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tu man ari dos?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— (Es) dos.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Cik liel?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Liel, liel, gaŗ kukiļ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bezdejs, bezdejs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no ko nāk tas lielais sūdu smaks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bezde, bezde, kas tur bezde? [smaks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kam tas lielais sūdu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mūsu tēvs, sēklu tēvs (~ mūsu papiņ, sēklu tēs),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ņem (jem) tos vadžus, plēš tos kokus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">peln tiem bērniem dieniško maizi!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Skait, kungs, pātarus!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es, vilks, nemāk: teļam pleišam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jēram gumžam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sive-nam kviugst!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Skait, vilk, pātarus!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">—Tēvureizi neprotu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bet es prot teļus pārplēst,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jērus grumzīt, sivenus</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kvīkšķināt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Radnieks (~ mājnieks) atbrouc,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaŗš vīz kāja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Duľ-doľ māniek,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaŗa vīze kāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bruceklis paduse,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">asais nazis blakus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Doľ-doľ rada vīrs...</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ting tong ārejs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gaŗa vīz kāja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dop-dop Rīga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārdopu mājas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārnes mammam kukliņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārnes papam (—tēvam) tabaciņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēvs brauc uz Rīg,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar mellem zirgem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kaltem ratem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nosole liel vēg atnest.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēs gāj Rīg,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jēm man līdz,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nopirk man biks,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vissmukak biks</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pa visu Rīgu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Siz ma tuľ kodai,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">siz ma voľ sūrli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ku min(nõn) tōťi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">knaš́š́õd bikšõd vostiz.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad nāc mājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad es bij lepns,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka vissmuks biks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dop-dop Rīga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saʼlskuli mugra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ābolis kabata,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">krinģelis zobos.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dop-dop Rīge,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārdop mājes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">atved krinģels,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">krinģels kabte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">salspods mugre.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dipa-dopa Rīgā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārdopa mājās,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sāls podiņš mugurā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">krinģeļi kabatā.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cērtu, cērtu, ko tu cērtu?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Eš‿jau cērtu piecpadsmit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas netic, lai nāk raudzit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai še nebūs piecpadsmit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Viens, div, trīs — viens tāds īss,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">deviņ, desmit — teļš bes tesmen.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">septiņ, astoņ — viens bez ast,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">četr, piec, seš — viens tāds svešs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Kas ir (~ bij) viens? — Es pats bij viens.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir div(i)? — Div ac piere.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir trīs? — Trīs kāj katļiņam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir četr? — Četr(i) ritiņ(i) ratiem (~ ratiņiem).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir piec? — Piec(i) pirkst(i) rokai.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir seš? — Seš(as) zvaigznes sietiņai (~ sietiņam).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir septiņ? — Septiņs dien(a)s nedeļam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir astoņ? — Astoņ vīr kalnu (~ kaliņ) rok.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas ir deviņ? — (Deviņ) tav suņ sūds uz degun gal.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Māte gāja klēti — es teceju pakal.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Māte man dev(a) rausi — es to rausi vējam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vējš man dev sieniņ — es to sieniņ goliņam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Goliš deva pieniņ — es to pieniņ kaķim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kaķis man dev dēlu — es to dēlu ozolam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ozols man dev zīles — es tas zīles cūkam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cūk man deva speķi — es to speķi kurpniekam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kurpnieks man dev kurpes — es tas kurpes brūtei.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Brūt man deva bučin — es to bučiņ leitim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Leitis man dev ķēvit — es to ķēvit vilkam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vilks man deva ādiņ — es to ādiņ žīdam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Žīds man deva drāniņ es to drāniņ savalkaj, šķilders šķelders žogmal.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1a. Kur tu teku (!), miegu peliņ, pai-pai-pai?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Pirti kurt, malku nest, pai-pai-pai.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tu noslāpsi dūmiņasi (!).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es palīšu palaveju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko tu ēsi, ko tu dzērsi, palaveiu palidusi?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Dubļus ēsi, dūņas dzērsi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tav piepumpsi vēderiti(s).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es pārdoršu ar adatu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Vai tas tevim nesāpesi?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es apsmēres ar sviestiņu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur tu sviestu ņemsi?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Veca māti bundaleju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur ta veca māte ņēma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Raiba goļa titiņasi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur ta raiba goļa ņēma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Zaļas niedras galiņeja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur ta zaļa niedra ņēma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Dziļas upes dibaneja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Kur tu teci, miega pele, pai, pai, pai?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Malku nesti, pirti kurti, pai, pai, pai.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tu noslāpsi dūminosi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es palienu pirts palaveii.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko tu ēdisi, ko tu dzērsi, palaveji palidusi?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur tu teku, miegu peli, pai-pai-pai?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Pirti kurti, malku nest, pai-pai-pai.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tu noslāpsi dūmiņas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es palīdiš palave.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko tu ēdis, ko tu dzērsi, palave palīdus?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Dūņu ēdišu, dubļus dzēršu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tu piepumpsi vēderiņš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es parduršu(!) ar adati.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Vai tas tevim nesāpes?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es apsmēres ar sviestiņu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur tu ņemsi to sviestiņu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Vecas mātes būndalēju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur ta vec māte ņēma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Raibu govu titiņas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur ta raiba gove ņēma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Zaļu niedru galiņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur ta zaļa niedra ņēma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Rīta rasa tam piedeva.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kur ta rīta rasa ņēma?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Dziļas upes dibena.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1a. Kur ta tu nu biju, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Sudmaleju, sudmaleju, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko ta tu tur darija, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Rudzus miežus bīdaleju, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kā ta tu tur bēra, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ar radziņu, ar radziņu, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ar ko ta tur slauce(ja), āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ar bārzdinu, ar bārzdinu, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ka ta tev tur gāja, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Slikti gāja, slikti gāja, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko ta tu tur darija, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es jau zagu, es jau zagu, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ko ta tu tur zagu, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kviešu miltus, kviešu miltus, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kas ta tevi noķēra, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Viena meita, viena meita, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Vai ta tevi nekūl, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kā tad ne, kā tad ne, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kā ta tu jel breice, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Buku bē, buku bē, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Kur ta tu nū bīji, āziti man?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Sudmalās, sudmalās, kundziņu man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es tev doš vien doz.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kas tur doze iekša būs?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tur būs trīs jaun kung.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kādas drēbes ģērbušes?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Viens būs melns, otrs zils,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trešais būs pelekais.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kuŗam dos?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Tav tas melnais,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tav tas pelekais</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un man tas zilais.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Akub nannõ vizzõ un kizub:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kur šnīp?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ezre.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kas tur iekša?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Ols.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kāda krāsa?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Zils, zaļš, sārkans, melns, zelts, sudrabs un — sūdains.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kād tu man dos?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es gāju mežā. — Es ari.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es nocirtu priedi. — Es ari.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es taisiju sili. — Es ari.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es dirsu iekšā. — Es ari.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mana cūka nāca un izēda. — ?!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Grib tu, meitiņ, miciņ šūt?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es grib šūt (vien) ērmig mič,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet pie vienu gailiņ lūgt(ies):</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīļa(!) gailiņ, ko liks klāt?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es likš savu sekstiņ klāt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Šnipu-šnapu, kas tas būs par (vien) ērmig mič!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es grib vienu miciņ šūt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet pie (vienu) vistiņ lūgt:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīļa vistiņ, ko liks klāt?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es likš savu oliņ klāt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gaiļa sekstiņ, vista(!) oliņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šnipu-šnapu, kas tas būs par (vien) ērmig mič.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es grib šūt vien ērmig micit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iet pie piliņ lūgties:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīļa piliņ, ko liks klāt?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es likš savu pīku-pēku klāt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gaiļa sekstiņ, vista(!) oliņ, pīku-pēku,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šnipu-šnapu, kas tas būs par (vien) ērmig mič!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es grib šūt ērmigo (!) micit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gaiļa ceksta, vista šnepa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pīļa kāja, zoša spalva —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ak kas par ērmigo micit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ait ast, cūk rember —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ak kas par ērmigo micit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ādamam bij septiņ dēl,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne tie ēda, ne tie dzēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne tie zinu(!) mīlestib,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un visi dara tā: </V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1a. Šim daldari, tam daldari,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tam jāiet no ta viena uz otru.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Mes ejam, mes ejam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par kalnam un par lejam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Te nāc viens lustigs dancotajs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kājam, rokam klopedams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tik dancosim, tik dancosim</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un citus neievērosim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1b. Mes ejam, mes ejam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par kalniem un par lejam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šē nākojas(!) viens luštigais dancotajs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kājam, rokam klopedams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mēs dancosim, mēs dancosim,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">citus neievērosim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mēs ejam, mēs ejam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">par kalniem un par lejam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Te ienāk lustigs dancotajs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar kājam, rokam klopedams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mēs dancosim, mēs dancosim,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(un) citus neievērosim.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Lai dārza, kas dārza —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bitit rožu dārza.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai pie vārda, kas pie vārda —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Līziņ Anniņ (vārda).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Bitit (~ dundurs) rožu dārziņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas tai (~ tam) vārds, kas tai vārds?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— N. N. (~ Maija) vārds, N. N, vārds.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai tev būtu N. N, vārds,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šogad vīru nedabus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja dabusi, tad dabusi</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pēc deviņiem vasariem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ložņa, bitit, caur zaru zariem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">caur zaru zariem, caur lapu lapam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja citu atrod, liec to sava vieta.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pēterits, Miķelits</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abi gāja peku lauzt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">abi divi piekusuši,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nevar peku kustinat.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai tik lauž, lai tik lauž,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lielas pekas nenolauž.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">1a. Zaķis savu tēvu tēvu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sila mala nobadij.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es gribej apraudat —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">smiekli nāca, nevarej.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lb. Zaķits manu vecu tēvu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sila mala nobadija.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es būt gauži noraudajis —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aiz smiekliemi nevareja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zaķis savu tēvu tēvu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">druva mala nobadij.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es gribeju apraudat —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">smiekli nāca, nevarej.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zaķis manu tēvu spēra</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar pakaļas kājiņam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es gribeju glābt iet —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">smiekli nāca, nevareju.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Šūpe, šūpe, vāveriņa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">savu mazu bērniņu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zaļa egles zariņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es šūpe sav maz bērniņ</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mīksta šūp(e)le uz ķisen.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vāvers lec uz vienu kok (uz otru kok)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ēiekars mekledami.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vāvers lec uz otru kok,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">čiekars mute,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nes savam bērnam ēst.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kaza, āzis augsta kalna, virsu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzelzs žogs visapkārt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">alvu atslēga priekša.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vilks lēca pāri žogam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lauza kāju pušu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">auns skrēja prom.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kaziņi buciņi uz kangariem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzelž(u) žogs apkārt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">misiņ atslēgs priekša,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sudrab slēdzamais iekša.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Miegaini kuceniņi, raibie suniši</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nes manu aunit ezermala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nes manam brālitim zelta pulkstenus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nes man māsiņam vainaga stīgas no zelta.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tiš-tuš už‿žoga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta brāliši už‿jumta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nes manai māsiņai skaistu vainagu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nes manam brālitim nesajamu-pulksteni.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nākat, meitas, lūkoties,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kādi ērmi tīruma:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pieci kaķi ārklu vilka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vāciets āra raudadams:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pašajami lielkungami</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pieci šurki ecišos (!).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ko tu doma, melnais runcis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz akmeni tupedams (~ sēdedams)?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Es domaju Rīga braukt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">peles krauti vezuma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kaķis brauc uz Rīg,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārnes sarkan puļķ(i),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bāz Dukšam apakš ast.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dukš skrej brēkdam uz Vārnu kalnu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaķis skrej pakaļ raudadam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Katriņ brauc Rīga,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārved sārkan puļķ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bāza Dukšam ausi (~ apakšast)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Duksis skrej(a) kriukdams uz Vārnu kalnu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Katriņš gāja brēkdams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēvs brauc uz Rīg,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pārved mātei cukur,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dukšam sārkan puļķi.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kaķis seid uz celm,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">beidigs galvu kasija:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mazums bija peles</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vezuma kraut.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Labak iešu antkamre</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie saimnieces peles medit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Antkamre ir krējumpods,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">peles netik ķērt.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saimniece runci kūla,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tas runcis nodarij?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Runcis mina vecu kaķi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aste mirka krejuma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Saiminiece runci kūla,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tas runcis padarija?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Runcis jāja otru kaķi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saimeniecei dūša nenes.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">5a. Saimniec kaķi sita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tas kaķis darija?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Kaķ(i)s nolaiza kreim(u) pod(u).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak tēvs, ak māt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">būs kaķam maziņ (~ maz bērn)!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas bija vainigs?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ciemiņa (~ sudmaļa) runcis.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar vīli vīleja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar zāģi zāģeja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar mazu ēveli</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nolīdzinaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pinciņ, runciņ, mazga kājs</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīte kaķam kāz būs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pinciņ, kaķiņ(!), mazga kājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīte nāks tevim sveši.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pincit, runcit, mazga kājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīte kaķim kāzas būs —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">liels kaķs vār menciti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">suns klaju galdiņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">4a. lnčiņ, rinčiņ, mazge kājs,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīte kaķem kāzes būs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Šovakar, šovakar</V>
'.
