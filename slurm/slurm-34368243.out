'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie laba vīra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar naudas kuli</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sasita stēndarus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vecmāt, vecmāt,</V>
'.
