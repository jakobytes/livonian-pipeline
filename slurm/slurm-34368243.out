WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neguļ ceļa maliņa:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rītu brauks lieli kungi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ņems tevi karite.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dirskāj tup krastmala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vēžs iekož dirse,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">žagarzūj kož vēž́am kāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jūrmaldilb knābe mugre,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jūŗas dil, jūŗas dil</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">putniņa mugre.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Nāč, bērn(i), skate,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas tur par brīnums aizkrāsne:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sienbuk spēl,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">blus dance</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakš gult ar žīd meitam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ej, bērn, skates,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas tur name dauzes:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">blus(a) kūl(a) circenit(i)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aiz matiemi turedams.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Klausat jauni, klausat veci,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kāds muziķis aizkrāsne:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">circeņam kāzas dzēr,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">blusa lēca panukste.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Spin, spin, bābiņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur man laimiņ —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vaī rītos, vaī vakaros,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vaī dienvidos?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lido, lido, vabuliti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rād, kur dzīvo man brūt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Skrien, skrien, vabolite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz to pusi, kur ir mans mīļakais!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiš, puiš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">griež vic, griež vic,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saimnieks nāk, saimnieks nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ķēv pļave, ķēv pļave,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzen āre, dzen āre!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Puiš, puiš, griež vic, griež vic,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ķēv pļave, ķēv pļave,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saimnieks nāk, saimnieks nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzen āre, dzen āre!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ri-rī, Rušk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vistiņ og pek.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Doš, doš, Dūmel, nebad Raibel!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. (Cīrulis dzieda, vasare nāk.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cep, māte, kukul(i), es iešu ganes.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja cepšu liel kukul, tad iešu tālak:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ja cepšu maz(iņ), tad vārtu gala.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">4a. Cīruliņ dzied, pavasars nāk.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Cep, māte, kukuli, es iešu ganos.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ja cepsi liel kukul, tad iešu tālu:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ja cepsi maz kukul, tad te pat tuvu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lelo, lelo, ciema gani,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man pazuda raibalite.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Viena pate govu gane,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man suns ir otrs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tuvi tāli, ganameit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man pazuda raibulit —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai palik iekš niedrajas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vai iekš baltu ābliņ lauk.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ēdat, govis, dzerat, govis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pildat savu vēderiņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai nerājas sveša māte,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai ir pilna slauktuviņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Ēdat, gojas, dzerat, gojas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pildat savus vēderus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">āboliņu mekledami,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pūŗu zāļu pieēduš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai nerāja sveša māt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es govis guldina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ēdat, goviņ, dzerat, goviņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pildat savs vēdarus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ābeliņu mekledami,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pūŗu zāļu pieēduš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ēdat,gojiņš, dzerat, gojiņš,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pildat savus vēdarus,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai nerāja sveša māt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka es govis guldina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Migla, migla, rasa, rasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu man labu nedarij:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rasa manim kājas sala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">migla zuda raibulit.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Migla, migla, rasa, rasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu man laba nedar:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">migla zūdu raibele,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rasa sala kājiņas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Migla, migla, rasa, rasa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tu man laba nedar:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">migla zūdu raibele,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rasa sala kājiņas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Līsti, līsti tu, lietiņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es par tevi nebaidos:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man ir lietus villainit</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">deviņam oḑeram.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Līst, lietiņa, viena stunda,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nelīst visa dieniņa!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lij, lietiņa, viena minut,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nelij visa stundiņa!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Steidz, steidz, saulit, tecet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīz saplīst, maizes nuk (~ rieciņš) nodilst.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Šķire, šķire, saulite,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka mīļa zošu ola.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Steidzies, saulit, pusdiena:.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vīze plīst, maize dilst.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka tas dzidrais ūdens skaidrojas</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, tec, sauliņ, drīz zeme —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ganinņam vīzs izirst.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Kā lai top mājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka liek ar basam kājam.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gara dien, saus maiz,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vērs dirs uz ilks.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak cik jauki (~ jautri),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ak cik jauki dzirdēt (~ klausities),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kuŗa pusi ganameit:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">meita nāk dziedadams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">suns nāk riedams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">govi nāk maudamies.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak tu slapja ganu meita,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka tu nāci raudot!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mākoņ nāk piledams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tauŗi nāk tuledams (tiledams),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūk nāk spēledam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jumprav nāk dancodam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ak tu, slapais mīzlains gans,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kā tu nāc brēkdams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cūk nāk spēledams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jumpravs nāk dancodams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">svilps nāk svilpodams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tauri nāk tauredams (~ fleits nāk spēledams).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Slapš un mīzlains ganiņš ir,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">gŗūta dzīve viņam ir:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mākoņi nāca piledami,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">taures skanet skaneja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Grūt bij, kam bij grūt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mazam ganiņam bij grūt:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">citi gani bāŗa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">krīt no koka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nāk no gaisa —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visi gana mugaŗa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bāŗa bērnam ganiņam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">varen gŗūta dzīve:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sveša māte vadot pēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">citi gani meže pēra.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte mani raida</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie ābeles rīkstes griezt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pie ābeles es piestājes</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka pie mīļas māmiņas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pirst ābelei balti ziedi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">birst man gaužas asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">2a. Pie ābeles piestājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sūdzu, ko man dara pamāte.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ābelei birst balti ziedi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">birst man sidrab asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tos dieviņš pats uzlasa</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sava zīďa nezdadziņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte ganos raida,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">maize līdze nedeva.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tad es sūdzu savai mātei,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko man dara sveša māte.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pie ābeles es piesēžejos(!)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ka pie savas māmiņas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ābelei birst balti ziedi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man birst gaužas asaras.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte mājas gaida,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vārtes vaļa vēra man.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad bij agri, tad man rāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad bij vēli, tad man kūla.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte maizi grieza,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pie pirkstiemi mēredams,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kumosiņas manim skaitij,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">lai es pulku neapēd.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte man soleja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">silta maize launage:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nebij silta, nebij auksta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bija dūru mugare.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visus ganus mājas gaida,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visiem vārtu vēreji —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">manam nav, kas mājas gaida.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte preti nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sveša māte vārtus vēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sveša māte vārtus vēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīkšu sauju paduse.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte preti nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vārtus vaļam vēra —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viena roka vārtus vēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">otra roka rīkstu sauja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ielaid mazu ganiņu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kūla maz ganiņa mugre.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi gani mājas dzina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visiem vārtu vērejiš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es ar būtu mājas dzinas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">man nav vārtu vērejš.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sveša māte pretim nāk,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">rīkste sauja paduse —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viena roka vārtes vēra,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">otra kūla ganiņu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad bij agri, tad rāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kad bij vēlu, tad kūla.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi gani mājas dzina —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pastaritis vien nebij (~ nedzina).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Visi govis laidra bija (~ mājas dzina) —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Balgališ vien nebij.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pastaritis Balgalitis</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">svēta Māŕa aploka.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pastariti(s) pina</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visam govam kronus galva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">no sīkem mazem bēržu lapam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Tec, sauliti, drīz pie dieva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tec, sauliti, pagaid mani,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es tev pateikšu:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aiznes manam māmuliņam</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dižas labas vakariņas.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, sauliti, drīz pie dieva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dod mums svētu vakaru.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Steidz, steidz, saule, tecet,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dod man svētu vakarin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rārgi bija tie kungi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nedod svēta vakarin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tec, saulite, drīz pie dieva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dod mums svētu vakariņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bārgi kungi dārbu deva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nedod svētu vakariņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Melna čūska miltus mala</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jūŗas vidu uz akmen,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tā maizite tam(i) kungam,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas pēc saules dārbu deva (~ strādinaj).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas tie tādi, kas dziedaja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pēc saulītes vakara?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie ir visi bāra bērni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bārgu kungu klausitāj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mērce avot pelu maize,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">to mumš‿jaēd.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ej, saulīte, drīz pie dieva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dod mums svētu vakaŗu!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bārgi kungi darbu deve,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nedev svētu vakaŗu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Melna čūska miltus maļu (~ mala)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">viduš‿jūŗa uz akmiņ —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tiem būs ēsties tiem kungiemi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas pēc saules strādaja (~ darbu dev).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kas tie tādi, kas dziedaja</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">apakš saules vakariņ?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie ir visi bāra bērni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bārgu kungu klausitaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">5a. Kas tie tādi, kas dziedaja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">saulit vēlu vakara?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tie ir visi bāŗa bērni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">bārga kunga klausitaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Krimta cieta pelu maize,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">avotiņa mirciņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zinu, zinu, bet neteikšu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur saulite nakti gul:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dziļas jūŗas vidiņā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">biezas egles galiņā.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Zinu, zinu, bet ne teikšu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur saulite nakti gul:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vide jūŗa uz akmiņu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zelta niedras galiņe.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es bij viens bāriņu bērns,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne man i tēvs, ne māt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne man i tēvs, ne māt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne ari mās un brāliņa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne ar kād žēlotaj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Bērž zari bij man šūplits</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un vējš man žūžotajs.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad es tik gauži raudaj,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: tad putni dziedaja :,: —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie mani nožēloj.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tēvu raudu pus mūž(iņu),</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māti raudu visu mūž.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Vienam tēvam 9 dēli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie visi 9 amata-brāļi:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3 puš stabuli, 3 sita bungu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3 velk tīklu gar jūras malu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pērkoņa tēvam deviņi dēli</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(visi deviņi amatnieki):</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs spēla [?], trīs rūca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs zibinaja.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">10a. Pērkoņam ir seši dēli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visi seši amatnieki:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">divi spēra, divi rūca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">divi gāja zibnedam.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tētiņ, tētiņ, cērt man laivu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māmiņ, aud man zēģelit!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es noiešu jūriņa</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar ziemeli cīnities.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Tēvs man taisa ošu laivu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">māte audu zēģeli.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tētiņ, tais man jaunu laivu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">aud, māmiņa, zēģelits,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tad es braukšu jūriņa</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar ziemeli cīnities.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Skrej, laiviņ, teci, laiviņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mūs jūre celmiņ nav.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Lai aug celmi arai mežos,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur araji arklus lauž.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Oša laiva, smaga laiva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">liepa laiva, viegla laiva:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">oša laiva smaga peld,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">liepa laiva viegla peld.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Sēd, meitiņ, mana laiva:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">mana laiva viegli peld,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta peld viegli pa ūdeni.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Nesēdišu tava laiva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">še tav zīdu lentiņa.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tek man laiviņ viegli,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vēiš un vētra gaŗam skrien,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">celm un akmiņ ceļu dod,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visas zivis pretim nāk</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un manu tīklu pilda!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Sviestiņ kope, :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: nabags aiz duŗam, :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Ieviņam dzer kāz. :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: Sviestiņ kope, :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: nabagam rīte kāzas dzer, :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">:,: nabags aiz duŗam. :,:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">3a. Sit, sit, sviestiņ,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vieši aiz durvim,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ienāks viņi iekša,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nebūs ko galda likt.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vāres, vāres, mans katlis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ciem katlis lai nevāres!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzied(a), tēvs, dzied(a), dēls,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzied abi kalp(a) dēl!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vairak dzied tēva dēl</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neka divi kalpa dēli.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Dzied, tēvs, dzied, dēls,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">dzied divi kalpa vīri,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vairak dzied tēvs ar dēlu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">neka divi kalpa vīri.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Knapi ļaudis godu gaida,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas knapiem godu dod —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne dubļu ziedi zied,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ne knapiem godu dod.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Piecus gadus kalpos gāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pieci kalpu kažociņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Kad es gāju sievu ņemti,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visi pieci mugura,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Suņi rēja ņigu-ņagu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kažoks grabu gribu-grabu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pieci gadi ganos gāja,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pelni pieci kažociņus.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jāņa nakti līgot gāju,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visi pieci mugura —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Čiema suņi niku-naku,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaž́ociņi briku-braku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rīga, Rīga, kas tav saukta,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur tie lepnie kungi brauka-</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kučeris ar lieliem bārdiem,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">seid (~ sēž) uz buku, laiž par ieliem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es vāciti(!) lecinaju</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz kārstem stiegelem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">o vāeitis augsti lēca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es pakūru uguntip.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad man būtu tā naudina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas gul jūras dibina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es nopirktu Rīgas pili</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar visiemi vācieš́iem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es vācieti daneinatu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz kārstiemi kiegeliem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jo vācietis augsti lēca,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">jo es kūra uguntinu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vācietim ir gari melni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">velna šūti zābacini.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">(Ar tiem varei ellē brist</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">līdz pašami dibinami.)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rīga dimd. Rīga dimd,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas to Rīgu dimdina?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trallalla, trallalla,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas to Rīgu dimdina.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Tai meitinai pūru kala,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kam trijadi bālelin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ka man būtu tā naudina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kas gul jūras dibena.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es nopirktu Rīgas pili</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ar visiemi vāciešiem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vācietim ir garas kājas,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">šauri šūti zābaki.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es vācieti lecinatu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz karstami stiegeliem.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jo vācietis augsti lēktu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">es pakurtu uguntin.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">5a. Vien muc porninš,</V>
'.
