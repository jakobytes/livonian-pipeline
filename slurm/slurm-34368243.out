'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ta kek(a)nieka tiesa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gan zinu, gan zinu</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kekniku tiesu:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kukali (~ kukuli) maizi,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs stopu alu —</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tas bija, tas bija</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kekniku ties(a).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Svīdeni, svīdeni,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">keknieku kukuls,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sausas pupas, zirnis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie ar tur klāt(u).</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gaila galva, vistas galva,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">un cūkas ciska,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sausas pupas, zirnis,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie ir tur klāti.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pīraki, pīraki</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tie vastlavju rauši.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gan zinu, gan zinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur galu glabas (~ glabaj):</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pažoble, pažoble,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tur galu glabas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es zinu, es zinu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kur galu glaba:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kamare nesa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz lubu lika,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">uz lubu lika,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">tais krustu virsu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Kad gāju pateikt,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">iedūru aci.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ace vel teces</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">līdz nākoš́gadu.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Es teikšu, es teikšu,</V>
'.
