'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">suns vāra mencit,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kaķis klāja galdiņ.</V>
'.
