'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">piemīza kurpes,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">nosala kājas.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Mīlaju māminu,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">laiž bērnus iekša!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Keknieku kērnami</V>
'.
