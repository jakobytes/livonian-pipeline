'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pats iegāja krodziņa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vistiņš vezum apēda.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Ar gailiti Riga brauce,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">trīs zirnišu vezuma.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Pats iegāja krodziņa,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zirgs apēda vezumiņ.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Krauklis lēca Rīga:</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">cik dārgas meitas?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">— Pus pīpes tabaka,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vien pelējušu mārku.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">la. Ai-ai zvirbuli, kad ņemšu sievu?</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Rudeni, rudeni par miežu laiku.</V>
'.
