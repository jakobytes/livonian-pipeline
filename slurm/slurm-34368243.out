'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vis(a) mūsu draudzite</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">suseklu zagli.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vectētin, vectētin,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">sarg savu īlen!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Gan zin(u), gan zin(u)</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">kekniku ties(u):</V>
'.
