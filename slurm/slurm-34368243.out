mkdir -p data/work/vldl
echo "collector_id,collector_name" > data/work/vldl/collectors.csv
csvstack data/work/skvr/collectors.csv data/work/erab/collectors.csv data/work/kr/collectors.csv data/work/vldl/collectors.csv > csvs/collectors.csv
mkdir -p data/work/skvr
python3 code/convert_skvr.py \
      -d data/work/skvr \
      --places-file data/raw/skvr/places.csv \
      --xml-types-file data/raw/skvr/tyyppiluettelo.xml \
      --json-types-file data/raw/skvr/themetree.json \
      --poem-types-file data/raw/skvr/viitteet_180221.txt \
  data/raw/skvr/skvr_*.xml
mkdir -p data/work/kr
( [ -f "data/raw/kr/places.csv" ] \
  && cp data/raw/kr/places.csv data/work/kr/places.csv ) \
|| ( echo "place_id,place_name,place_type,place_parent_id" > data/work/kr/places.csv )
mkdir -p data/work/vldl
( echo "place_id,place_name,place_type,place_parent_id" > data/work/vldl/places.csv )
echo "vldl_0100,Livonian coast,county," >> data/work/vldl/places.csv
csvstack data/work/skvr/places.csv data/work/erab/places.csv data/work/kr/places.csv data/work/vldl/places.csv > csvs/places.csv
python3 code/compute_county_polygons.py -G 10 -H 1000000 \
  --areas-file data/raw/areas.geojson \
  --polygon-to-place-file data/raw/polygon_to_place.csv \
  --places-file csvs/places.csv > csvs/counties.geojson
