'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tie ēd un ko tie dzer,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">ko tie sēja zemite.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānis sēž kalnina,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">visapkārt jāna bērni.</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Jānits skatii lejina,</V>
