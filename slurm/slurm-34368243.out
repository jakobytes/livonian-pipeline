'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Treknas plekstes mūsu jūrā,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">vājas plekstes mazā jūrā (Rigas līeī)!</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">Vlmbad, törskad mäddō mjerrō,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">knaššōd neitsōd mäddō küllō!</V>
'.
