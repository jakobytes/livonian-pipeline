'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">pūtite samina zvirbuli kāju,</V>
'.
WARNING:root:Pattern '<V>(.*)</V>' does not match string '<V lang="lav">zvirbuli(s) isknāba pūcitem aci.</V>
'.
